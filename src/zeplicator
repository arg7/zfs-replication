#!/bin/bash

# zeplicator - Modular ZFS Replication Manager
# Main orchestrator script

ZEPLICATOR_CMD="$(readlink -f "$0")"
LIB_DIR=$(dirname "$ZEPLICATOR_CMD")

# Phase 1: Source library modules
source "${LIB_DIR}/zfs-common.lib.sh"
source "${LIB_DIR}/zfs-status.lib.sh"
source "${LIB_DIR}/zfs-alerts.lib.sh"
source "${LIB_DIR}/zfs-retention.lib.sh"
source "${LIB_DIR}/zfs-transfer.lib.sh"

# Initialize default variables
raw_dataset=""
label="frequently"
keep_fallback="10"

usage() {
    cat <<EOF
zeplicator - Modular ZFS Replication Manager

Usage:
  $(basename "$0") <dataset> [label] [keep_fallback] [flags]

Positional Arguments:
  <dataset>         The ZFS dataset to replicate (e.g., tank/data).
                    Can be a remote alias if 'zep:node:<alias>:fs' is set.
  [label]           Snapshot label to filter/create (default: frequently).
  [keep_fallback]   Default number of snapshots to keep if not configured (default: 10).

Primary Flags:
  --dry-run         Simulate the entire replication chain without making changes.
                    Mocks snapshot creation, transfers, property sync, and rotation.
  --auto            Automatically resolve latest common snapshot during promotion.
  --promote         Promote the local node to Master in the replication chain.
  --initial         Perform an initial replication (uses full stream, mbuffer/zstd).
  --suspend/resume  Suspend or resume replication across the entire chain.
  --config          Enter configuration mode to view/set/clear 'zep:' ZFS properties.
  --status          Probe and display system status for the replication chain.
  --alias <name>    Manually specify the local node alias (overrides hostname detection).

Advanced Flags:
  --mark-only       Only perform rotation/cleanup of already shipped snapshots.
  --destroy-chain   Force a fresh start when promoting if no common ground exists.
  --snap <name>     Specify a literal snapshot name to use for promotion/rollback.
  --target <node>   Point-to-point transfer to a specific node (ignores chain).
  --donor           Run as a donor peer to heal a downstream node.
  -y                Assume 'yes' for destructive operations (promotion/rollback).
  --help, -h        Show this help message.

Configuration Mode (--config):
  $(basename "$0") <dataset> --config [subcommand]

  --list            (Default) List all 'zep:' properties.
  --clear <key>     Remove a specific property (e.g., smtp:port).
  --export <file>   Save all 'zep:' properties to a file.
  --import <file>   Load 'zep:' properties from a file.
  key=value         Set a property. Supports shorthands:
                    'smtp:host=...' expands to 'zep:smtp_host=...'
                    'node:n1:fqdn=...' expands to 'zep:node:n1:fqdn=...'

Configuration Examples:
  Set chain:      zfs set zep:chain=node1,node2,node3 tank/data
  Set retention:  zfs set zep:node:node1:keep:frequently=30 tank/data
  View config:    zeplicator tank/data --config

EOF
    exit 0
}

MARK_ONLY=false
initial_send=false
PROMOTE=false
CASCADED=false
SUSPEND=false
RESUME=false
AUTO=false
DRY_RUN=false
VIRTUAL_SNAPS_INCOMING=""
VIRTUAL_SNAP_CREATED=""
DESTROY_CHAIN=false
YES=false
PROMOTE_SNAP=""
sync_props_data=""
TARGET_NODE=""
IS_DONOR=false
CONFIG_MODE=false
config_args=()
STATUS_MODE=false

CLI_ALIAS=""

# Parse arguments
positional_args=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        --help|-h) usage ;;
        --alias) CLI_ALIAS="$2"; shift 2 ;;
        --mark-only) MARK_ONLY=true; shift ;;
        --initial) initial_send=true; shift ;;
        --promote) PROMOTE=true; shift ;;
        --suspend) SUSPEND=true; shift ;;
        --resume) RESUME=true; shift ;;
        --cascaded) CASCADED=true; shift ;;
        --auto) AUTO=true; shift ;;
        --destroy-chain) DESTROY_CHAIN=true; shift ;;
        -y) YES=true; shift ;;
        --snap) PROMOTE_SNAP="$2"; shift 2 ;;
        --sync-props) sync_props_data="$2"; shift 2 ;;
        --target) TARGET_NODE="$2"; shift 2 ;;
        --donor) IS_DONOR=true; shift ;;
        --dry-run) DRY_RUN=true; shift ;;
        --snap-list) VIRTUAL_SNAPS_INCOMING="$2"; shift 2 ;;
        --status) STATUS_MODE=true; shift ;;
        --get-state) GET_STATE_MODE=true; shift ;;
        --config) 
            CONFIG_MODE=true
            shift
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --list|--clear|--export|--import) config_args+=("$1"); shift ;;
                    -*) break ;; # Next main flag
                    *) config_args+=("$1"); shift ;;
                esac
            done
            ;;
        -*) echo "Unknown flag: $1"; shift ;; # Ignore unknown flags
        *) positional_args+=("$1"); shift ;; # Collect positional arguments
    esac
done

# Assign positional arguments
if [[ ${#positional_args[@]} -gt 0 ]]; then raw_dataset="${positional_args[0]}"; fi
if [[ ${#positional_args[@]} -gt 1 ]]; then label="${positional_args[1]}"; fi
if [[ ${#positional_args[@]} -gt 2 ]]; then keep_fallback="${positional_args[2]}"; fi

if [[ "$STATUS_MODE" != true ]]; then if [[ "$STATUS_MODE" != true && "$GET_STATE_MODE" != true ]]; then [[ -n "$raw_dataset" ]] || usage; fi; fi

# Early local dataset resolution
my_hostname=$(get_local_alias "$raw_dataset" "$CLI_ALIAS")

# Resolve local pool name from node-specific property (e.g., zep:node:<alias>:fs=node1-pool/data1)
configured_ds=$(get_zfs_prop "zep:node:${my_hostname}:fs" "$raw_dataset")

if [[ -n "$configured_ds" && "$configured_ds" != "-" ]]; then
    local_ds="$configured_ds"
else
    # Fallback to legacy or simple pool/ds resolution
    ds_name="${raw_dataset#*/}"
    configured_pool=$(get_zfs_prop "zep:node:${my_hostname}:fs" "$raw_dataset")
    if [[ -n "$configured_pool" && "$configured_pool" != "-" ]]; then
        if [[ "$configured_pool" == *"/"* ]]; then
            local_ds="$configured_pool"
        else
            local_ds="${configured_pool}/${ds_name}"
        fi
    else
        # Last resort fallback: use the provided name directly
        local_ds="$raw_dataset"
        REPL_CHAIN=$(get_zfs_prop "zep:chain" "$raw_dataset")
    fi
fi

if [[ "$CASCADED" != true ]]; then
    expected_ds=$(get_zfs_prop "zep:node:${my_hostname}:fs" "$raw_dataset")
    if [[ -n "$expected_ds" && "$expected_ds" != "-" ]]; then
        if [[ ! "$local_ds" =~ ^"$expected_ds" ]]; then
            echo -e "${C_YELLOW}⚠️  Dataset $local_ds is not managed by node $my_hostname (configured: $expected_ds)${C_RESET}"
            exit 1
        fi
    fi
fi

dataset=$local_ds # Ensure helper functions use the local path

# Handle Status logic
if [[ "$STATUS_MODE" == true ]]; then
    cmd_status "$raw_dataset"
    exit $?
fi

# Handle Configuration logic
handle_config() {
    local args=("$@")

    expand_shorthand() {
        local k="$1"
        if [[ "$k" != zep:* ]]; then
            if [[ "$k" == smtp:* ]]; then
                echo "zep:smtp_${k#*:}"
            else
                echo "zep:$k"
            fi
        else
            echo "$k"
        fi
    }

    if [[ ${#args[@]} -eq 0 || "${args[0]}" == "--list" ]]; then
        echo "  📋 Current Configuration for $dataset:"
        zfs get all -H -o property,value "$dataset" | grep "^zep:" | sed 's/^zep://' | sort | awk -F'\t' '{ printf "      %-30s %s\n", $1, $2 }'
        return
    fi

    local i=0
    while [[ $i -lt ${#args[@]} ]]; do
        local arg="${args[i]}"
        
        if [[ "$arg" == "--export" ]]; then
            local fname="${args[((i+1))]}"
            [[ -z "$fname" || "$fname" == -* ]] && die "Missing filename for --export"
            
            echo "  💾 Exporting configuration to $fname..."
            zfs get all -H -o property,value "$dataset" | grep "^zep:" | awk -F'\t' '{print $1"="$2}' > "$fname"
            i=$((i + 2))
            continue
        fi

        if [[ "$arg" == "--import" ]]; then
            local fname="${args[((i+1))]}"
            [[ -z "$fname" || ! -f "$fname" ]] && die "Missing or invalid filename for --import"
            
            echo "  📥 Importing configuration from $fname..."
            while IFS= read -r line || [[ -n "$line" ]]; do
                # Trim whitespaces
                line="$(echo "$line" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
                [[ -z "$line" || "$line" == \#* ]] && continue
                
                if [[ "$line" == *"="* ]]; then
                    local key="${line%%=*}"
                    local val="${line#*=}"
                    
                    key=$(expand_shorthand "$key")
                    
                    echo "  ⚙️  Setting $key=$val on $dataset"
                    zfs set "$key=$val" "$dataset" || echo "    ⚠️  Failed to set $key"
                fi
            done < "$fname"
            i=$((i + 2))
            continue
        fi

        if [[ "$arg" == "--clear" ]]; then
            local key="${args[((i+1))]}"
            [[ -z "$key" ]] && die "Missing property key to clear"
            
            local full_key=$(expand_shorthand "$key")

            echo "  ⚙️  Clearing $full_key from $dataset..."
            zfs inherit "$full_key" "$dataset" || echo "    ⚠️  Failed to clear $full_key"
            i=$((i + 2))
            continue
        fi

        if [[ "$arg" == *"="* ]]; then
            local key="${arg%%=*}"
            local val="${arg#*=}"
            
            local full_key=$(expand_shorthand "$key")
            
            echo "  ⚙️  Setting $full_key=$val on $dataset"
            zfs set "$full_key"="$val" "$dataset" || echo "    ⚠️  Failed to set $full_key"
        else
            echo "  ⚠️  Ignoring invalid config argument: $arg (Expected key=value)"
        fi
        i=$((i + 1))
    done
}

if [[ "$CONFIG_MODE" == true ]]; then
    handle_config "${config_args[@]}"
    exit 0
fi

# Identity & Configuration Discovery
REPL_CHAIN=$(get_zfs_prop "zep:chain" "$local_ds")
REPL_USER=$(get_zfs_prop "zep:user" "$local_ds")
REPL_POLICY=$(get_zfs_prop "zep:policy" "$local_ds")
REPL_SSH_TIMEOUT=$(resolve_ssh_timeout "$local_ds")
REPL_TIMEOUT=$(resolve_proc_timeout "$local_ds")
[[ -z "$REPL_USER" ]] && REPL_USER="root"
[[ -z "$REPL_POLICY" || "$REPL_POLICY" == "-" ]] && REPL_POLICY="fail"

# Handle Suspend/Resume logic
if [[ "$SUSPEND" == true || "$RESUME" == true ]]; then
    ACTION="SUSPENDED"
    VAL="true"
    if [[ "$RESUME" == true ]]; then 
        ACTION="RESUMED"
        VAL="false"
    fi

    echo "  🛡️  ${ACTION} replication for $raw_dataset..."
    
    CURRENT_CHAIN=$(get_zfs_prop "zep:chain" "$local_ds")
    if [[ -z "$CURRENT_CHAIN" ]]; then
        die "ERR: Cannot ${ACTION}, no existing zep:chain found on $local_ds. Please run from a configured node."
    fi

    IFS=',' read -r -a nodes <<< "$CURRENT_CHAIN"
    for n in "${nodes[@]}"; do
        n_fqdn=$(resolve_node_fqdn "$n" "$local_ds")
        n_user=$(resolve_node_user "$n" "$local_ds")
        n_ds=$(resolve_node_dataset "$n" "$local_ds")
        echo "    ⏳ Setting zep:suspend=$VAL on $n ($n_fqdn)..."
        ssh "${n_user}@${n_fqdn}" "zfs set zep:suspend=$VAL ${n_ds}" || echo "  Warning: Failed to set property on $n"
    done
    
    send_smtp_alert "info" "NOTICE: ZFS Replication has been ${ACTION} for dataset $raw_dataset on $my_hostname. Master node: ${nodes[0]}. New state: zep:suspend=$VAL"
    exit 0
fi

# Sync properties to nodes during promotion
sync_promotion_props() {
    local ds_path=$1
    local target_nodes_ref=$2
    eval "local target_nodes=(\"\${$target_nodes_ref[@]}\")"
    local props_encoded=$(get_repl_props_encoded "$ds_path")
    local props_decoded=$(echo -n "$props_encoded" | base64 -d)
    local unreachable=()

    echo "  ⚙️  Syncing replication properties..."
    for n in "${target_nodes[@]}"; do
        [[ "$n" == "$my_hostname" ]] && continue
        local n_fqdn=$(resolve_node_fqdn "$n" "$raw_dataset")
        local n_user=$(resolve_node_user "$n" "$raw_dataset")
        local n_ds=$(resolve_node_dataset "$n" "$raw_dataset")
        echo -n "    - $n ($n_fqdn)... "
        
        ssh "${n_user}@${n_fqdn}" "bash -s" <<EOF >/dev/null 2>&1
            IFS=';' read -ra props <<< "$props_decoded"
            for p in "\${props[@]}"; do
                [[ -z "\$p" ]] && continue
                k="\${p%%=*}"
                v="\${p#*=}"
                curr=\$(zfs get -H -o value "\$k" "$n_ds" 2>/dev/null)
                if [[ "\$curr" != "\$v" ]]; then
                    zfs set "\$p" "$n_ds"
                fi
            done
EOF
        if [[ $? -eq 0 ]]; then
            echo "✅"
        else
            echo "❌"
            unreachable+=("$n")
        fi
    done
    
    echo ""
    if [[ ${#unreachable[@]} -eq 0 ]]; then
        echo "  🎉 SUCCESS: Promotion complete! Node $my_hostname is now Master."
    else
        echo "  ⚠️  PARTIAL SUCCESS: Node $my_hostname is Master, but some nodes were unreachable: ${unreachable[*]}"
        echo "     Replication will attempt to heal them during the next cycle."
    fi
}

# Handle Promotion logic
if [[ "$PROMOTE" == true ]]; then
    echo "  🚀 Promoting $my_hostname to Master..."
    
    CURRENT_CHAIN=$(get_zfs_prop "zep:chain" "$local_ds")
    if [[ -z "$CURRENT_CHAIN" ]]; then die "ERR: Cannot promote, no existing zep:chain found on $local_ds"; fi

    IFS=',' read -r -a nodes <<< "$CURRENT_CHAIN"
    NEW_NODES=("$my_hostname")
    for n in "${nodes[@]}"; do
        if [[ "$n" != "$my_hostname" ]]; then
            NEW_NODES+=("$n")
        fi
    done
    NEW_CHAIN=$(IFS=','; echo "${NEW_NODES[*]}")
    
    if [[ "$CURRENT_CHAIN" == "$NEW_CHAIN" ]]; then
        echo "  $my_hostname is already Master in local config."
        exit 0
    fi

    if [[ "$AUTO" == true || -n "$PROMOTE_SNAP" || "$DESTROY_CHAIN" == true ]]; then
        TARGET_SNAP=""
        declare -a REACHABLE_NODES=()
        declare -a UNREACHABLE_NODES=()

        if [[ -n "$PROMOTE_SNAP" ]]; then
            TARGET_SNAP="$PROMOTE_SNAP"
            echo "  🔍 Verifying snapshot @$TARGET_SNAP consistency..."
            for n in "${NEW_NODES[@]}"; do
                echo -n "    - $n... "
                local_ds_target=$(resolve_node_dataset "$n" "$raw_dataset")
                local_fqdn=$(resolve_node_fqdn "$n" "$raw_dataset")
                local_user=$(resolve_node_user "$n" "$raw_dataset")
                g=$(ssh "${local_user}@${local_fqdn}" "zfs get -H -o value guid ${local_ds_target}@$TARGET_SNAP" 2>/dev/null)
                if [[ -n "$g" && "$g" != "-" ]]; then
                    echo "✅"
                    REACHABLE_NODES+=("$n")
                else
                    echo "❌"
                    UNREACHABLE_NODES+=("$n")
                fi
            done
            [[ -z "${REACHABLE_NODES[0]}" ]] && die "ERR: Snapshot @$TARGET_SNAP not found on any reachable node."
        else
            echo "  🔍 Auto-discovering latest common snapshot..."
            tmp_common="/tmp/zfs-common-snaps.$$"
            f_node_flag=true
            
            for n in "${NEW_NODES[@]}"; do
                echo -n "    - Querying $n... "
                local_ds_target=$(resolve_node_dataset "$n" "$raw_dataset")
                local_fqdn=$(resolve_node_fqdn "$n" "$raw_dataset")
                local_user=$(resolve_node_user "$n" "$raw_dataset")
                node_target="${local_user}@${local_fqdn}"

                node_tmp="/tmp/zfs-node-snaps.$$"
                query_ok=false
                if [[ "$n" == "$my_hostname" ]]; then
                    zfs list -t snap -H -o guid -r "${local_ds_target}" 2>/dev/null > "$node_tmp" && query_ok=true
                else
                    if timeout "$REPL_SSH_TIMEOUT" ssh -o ConnectTimeout="$REPL_SSH_TIMEOUT" -o BatchMode=yes "$node_target" "zfs list -t snap -H -o guid -r ${local_ds_target}" 2>/dev/null > "$node_tmp"; then
                        query_ok=true
                    fi
                fi

                if [[ "$query_ok" == true ]]; then
                    echo "✅"
                    REACHABLE_NODES+=("$n")
                    if [[ "$f_node_flag" == true ]]; then
                        mv "$node_tmp" "$tmp_common"
                        f_node_flag=false
                    else
                        grep -Fxf "$tmp_common" "$node_tmp" > "${tmp_common}.new"
                        mv "${tmp_common}.new" "$tmp_common"
                        rm -f "$node_tmp"
                    fi
                else
                    echo "❌"
                    UNREACHABLE_NODES+=("$n")
                    rm -f "$node_tmp"
                fi
                [[ ! -s "$tmp_common" && "$f_node_flag" == false ]] && break
            done

            if [[ -s "$tmp_common" ]]; then
                TARGET_GUID=""
                while read -r local_guid; do
                    if grep -qx "$local_guid" "$tmp_common"; then
                        TARGET_GUID="$local_guid"
                    fi
                done < <(zfs list -t snap -H -o guid -r "$local_ds")

                if [[ -n "$TARGET_GUID" ]]; then
                    local_info=$(zfs list -t snap -H -o name,guid -r "$local_ds" | grep "$TARGET_GUID" | head -n 1)
                    TARGET_SNAP=$(echo "$local_info" | awk '{print $1}' | cut -d'@' -f2)
                    target_guid=$(echo "$local_info" | awk '{print $2}')
                    echo "  🔗 Found latest common snapshot: @$TARGET_SNAP"
                else
                    die "ERR: Could not resolve any common snapshot GUID locally."
                fi
            fi
            rm -f "$tmp_common"
        fi

        if [[ "$DESTROY_CHAIN" == true && -n "$TARGET_SNAP" ]]; then
            echo "ABORT: Common snapshot @$TARGET_SNAP found! Destruction is NOT necessary."
            exit 1
        fi
        
        if [[ "$AUTO" == true || -n "$PROMOTE_SNAP" ]]; then
            if [[ -z "$TARGET_SNAP" ]]; then
                die "ERR: Could not find a common snapshot across all nodes. Use --destroy-chain if you want to start fresh."
            fi

            if [[ "$YES" != true ]]; then
                echo -n "Are you sure you want to rollback ALL nodes in the chain to @$TARGET_SNAP? (y/N): "
                read -r resp
                if [[ "$resp" != "y" ]]; then die "Aborted by user."; fi
            fi

            echo "  🔄 Rolling back reachable nodes to @$TARGET_SNAP..."
            for n in "${REACHABLE_NODES[@]}"; do
                echo -n "    - $n... "
                local_ds_target=$(resolve_node_dataset "$n" "$raw_dataset")
                local_fqdn=$(resolve_node_fqdn "$n" "$raw_dataset")
                local_user=$(resolve_node_user "$n" "$raw_dataset")
                if [[ "$n" == "$my_hostname" ]]; then
                    zfs rollback -r "${local_ds_target}@$TARGET_SNAP" && echo "✅" || die "ERR: Local rollback failed"
                else
                    ssh "${local_user}@${local_fqdn}" "zfs rollback -r ${local_ds_target}@$TARGET_SNAP" && echo "✅" || echo "❌"
                fi
            done
            
            echo "  ✨ Updating local chain configuration..."
            zfs set zep:chain="$NEW_CHAIN" "$local_ds"
            send_smtp_alert "info" "NOTICE: Node $my_hostname has been PROMOTED to Master for dataset $raw_dataset. New chain: $NEW_CHAIN"

            sync_promotion_props "$local_ds" "NEW_NODES"
            exit 0
        fi
    fi
    # If we are here and PROMOTE=true, it means no auto/snap/rollback was requested,
    # but we should still sync the new chain configuration and exit.
    if [[ "$PROMOTE" == true ]]; then
        echo "  ✨ Updating local chain configuration..."
        zfs set zep:chain="$NEW_CHAIN" "$local_ds"
        send_smtp_alert "info" "NOTICE: Node $my_hostname has been PROMOTED to Master for dataset $raw_dataset. New chain: $NEW_CHAIN"

        sync_promotion_props "$local_ds" "NEW_NODES"
        exit 0
    fi
fi 

# Apply propagated properties
if [[ -n "$sync_props_data" && "$PROMOTE" != true ]]; then
    if zfs list "$local_ds" >/dev/null 2>&1; then
        apply_repl_props "$local_ds" "$sync_props_data"
    else
        echo "INFO: Dataset $local_ds not found, skipping property sync (likely initial run)."
    fi
fi

ME=$(get_local_alias "$local_ds" "$CLI_ALIAS")
CLI_ALIAS="$ME" # Update global CLI_ALIAS with resolved value for lock file
NEXT_HOP=""
IS_MASTER=false
ME_INDEX=-1
RESOLVED_KEEP=$keep_fallback
CHAIN_PREFIX=""

if [[ -n "$REPL_CHAIN" ]]; then
    IFS=',' read -r -a nodes <<< "$REPL_CHAIN"
    
    # Pre-flight dependency check (only if --initial is set and NOT a cascaded call)
    if [[ "$initial_send" == true && "$CASCADED" == false ]]; then
        echo -e "${CHAIN_PREFIX}  ${C_CYAN}🛠️${C_RESET}  Pre-flight: Checking dependencies (mbuffer, zstd) across all nodes..."
        for n in "${nodes[@]}"; do
            n_fqdn=$(resolve_node_fqdn "$n" "$local_ds")
            n_user=$(resolve_node_user "$n" "$local_ds")
            
            echo -e "${CHAIN_PREFIX}    ${C_CYAN}🔍 Checking $n ($n_fqdn)...${C_RESET}"
            if ! timeout "$((REPL_SSH_TIMEOUT + 5))" ssh -o ConnectTimeout="$REPL_SSH_TIMEOUT" -o BatchMode=yes "${n_user}@${n_fqdn}" "which mbuffer >/dev/null && which zstd >/dev/null"; then
                die "Missing dependencies (mbuffer or zstd) or connection timeout on node: $n ($n_fqdn). Please install them before proceeding with --initial."
            fi
        done
        echo -e "${CHAIN_PREFIX}  ${C_GREEN}✅ All nodes verified.${C_RESET}"
    fi

    NODES_REMAINING=()
    for i in "${!nodes[@]}"; do
        if [[ "${nodes[i]}" == "$ME" ]]; then
            ME_INDEX=$i
            if [[ $i -eq 0 ]]; then IS_MASTER=true; fi
            for (( j=i+1; j<${#nodes[@]}; j++ )); do
                NODES_REMAINING+=("${nodes[j]}")
            done
            if (( ${#NODES_REMAINING[@]} > 0 )); then
                NEXT_HOP="${REPL_USER}@${NODES_REMAINING[0]}"
            fi
            break
        fi
    done
    [[ $ME_INDEX -eq -1 ]] && die "ERR: Host $ME is not part of the replication chain for $local_ds"
    
    if [[ -z "$CHAIN_PREFIX" ]]; then
        for (( i=0; i<ME_INDEX; i++ )); do
            CHAIN_PREFIX+="  | "
        done
    else
        # If passed from upstream, add one more level
        CHAIN_PREFIX+="  | "
    fi
    
    dry_flag=""
    [[ "$DRY_RUN" == true ]] && dry_flag=" [DRY RUN]"
    echo -e "${CHAIN_PREFIX}${C_CYAN}🏁 Start${C_RESET}${dry_flag}: $(date); Dataset: $local_ds; Label: $label"
    
    RESOLVED_KEEP=$(resolve_retention "$local_ds" "$label" "$keep_fallback")
    echo -e "${CHAIN_PREFIX}  ${C_BLUE}🛡️${C_RESET}  Using dynamic retention for $label: $RESOLVED_KEEP (Role: $( [[ $ME_INDEX -eq 0 ]] && echo "master" || ( [[ $ME_INDEX -eq $((${#nodes[@]}-1)) ]] && echo "sink" || echo "middle" ) ))"
fi

if [[ -n "$TARGET_NODE" ]]; then
    NODES_REMAINING=("$TARGET_NODE")
    IS_MASTER=true
fi

# --- HEARTBEAT MONITORING LOGIC ---
if [[ "$IS_MASTER" == false ]]; then
    # 1. Check for heartbeat property
    HB_PROP="zep:alert:heartbeat:${label}"
    HB_THRESHOLD_RAW=$(get_zfs_prop "$HB_PROP" "$local_ds")
    
    if [[ "$HB_THRESHOLD_RAW" != "-" ]]; then
        # 2. Parse threshold to seconds
        HB_THRESHOLD_SEC=$(parse_time_to_seconds "$HB_THRESHOLD_RAW")
        
        # 3. Find latest snapshot for label
        LATEST_SNAP_NAME=$(zfs list -t snap -o name -H -S creation -r "$local_ds" | grep "@.*$label" | head -n 1)
        
        if [[ -n "$LATEST_SNAP_NAME" ]]; then
            # 4. Calculate age in seconds
            SNAP_TIME=$(zfs get -H -o value creation "$LATEST_SNAP_NAME")
            SNAP_EPOCH=$(date -d "$SNAP_TIME" +%s)
            NOW_EPOCH=$(date +%s)
            AGE_SEC=$(( NOW_EPOCH - SNAP_EPOCH ))
            
            # 5. If age exceeds threshold, alert
            if [[ $AGE_SEC -gt $HB_THRESHOLD_SEC ]]; then
                send_smtp_alert "critical" "CRITICAL: Upstream chain silent for label '${label}' on '${local_ds}'. Latest snapshot '${LATEST_SNAP_NAME}' is $((AGE_SEC/60)) minutes old (threshold: ${HB_THRESHOLD_RAW})."
            fi
        fi
    fi
fi
# --- END HEARTBEAT MONITORING ---

if [[ "$IS_MASTER" == false && "$CASCADED" == false && "$PROMOTE" == false && "$MARK_ONLY" == false && -z "$TARGET_NODE" && "$IS_DONOR" == false ]]; then
    echo "${CHAIN_PREFIX}  ℹ️  Node $ME is not Master. Skipping initiation (Cron safety)."
    exit 0
fi

if [[ "$IS_MASTER" == true && "$CASCADED" == false && "$PROMOTE" == false && -z "$TARGET_NODE" ]]; then
    SUSPEND_STATE=$(get_zfs_prop "zep:suspend" "$local_ds")
    if [[ "$SUSPEND_STATE" == "true" ]]; then
        echo "${CHAIN_PREFIX}  🛑 Replication is SUSPENDED (zep:suspend=true). Skipping run."
        exit 0
    fi
fi


if [[ "$MARK_ONLY" == true ]]; then
    if [[ "$IS_MASTER" == true ]]; then
        purge_shipped_snapshots "$local_ds" "$label" "$RESOLVED_KEEP"
    fi
    exit 0
fi

dataset="$local_ds"

# 1. Snapshot creation (Master only)
if [[ "$IS_MASTER" == true && "$CASCADED" == false && "$PROMOTE" == false && -z "$TARGET_NODE" && "$IS_DONOR" == false ]]; then
    timestamp=$(date -u +%Y-%m-%d-%H%M)
    snap_name_base="zeplicator_${label}-${timestamp}"
    snap_name="${local_ds}@${snap_name_base}"

    if [[ "$DRY_RUN" == true ]]; then
        echo -e "${CHAIN_PREFIX}  ${C_YELLOW}⏳${C_RESET} [DRY RUN] Would create snapshot: $snap_name"
        VIRTUAL_SNAP_CREATED="$snap_name_base"
    elif zfs list -t snap "$snap_name" >/dev/null 2>&1; then
        echo -e "${CHAIN_PREFIX}  ${C_YELLOW}⏳${C_RESET} Snapshot $snap_name already exists. Reusing..."
    else
        echo -e "${CHAIN_PREFIX}  ${C_YELLOW}⏳${C_RESET} Creating snapshot: $snap_name"
        zfs snapshot "$snap_name" 2>&1 | indent_output
        [[ ${PIPESTATUS[0]} -eq 0 ]] || die "ERR: snapshot creation failed"
    fi
else
    if [[ "$IS_DONOR" == true ]]; then
        echo "${CHAIN_PREFIX}  ℹ️  Node $ME is acting as Donor. Skipping snapshot creation."
    elif [[ -n "$TARGET_NODE" ]]; then
        echo "${CHAIN_PREFIX}  ℹ️  Point-to-point transfer to $TARGET_NODE. Skipping snapshot creation."
    elif [[ "$PROMOTE" == true ]]; then
        echo "${CHAIN_PREFIX}  ℹ️  Promoting chain. Skipping initial snapshot creation."
    else
        echo "${CHAIN_PREFIX}  ℹ️  Not a master host ($ME), skipping snapshot creation."
    fi
fi

check_stuck_job

LATEST_SNAP=$(zfs list -t snap -o name -H -S creation -r "$local_ds" | grep "@.*$label" | head -n 1 | cut -d'@' -f2)
if [[ "$DRY_RUN" == true && -n "$VIRTUAL_SNAP_CREATED" ]]; then
    LATEST_SNAP="$VIRTUAL_SNAP_CREATED"
fi

# If we are in a cascaded/donor run and still don't have a LATEST_SNAP by label,
# use the literal latest snapshot available to ensure verification logic has something to check.
if [[ -z "$LATEST_SNAP" && ( "$CASCADED" == true || "$IS_DONOR" == true ) ]]; then
    LATEST_SNAP=$(zfs list -t snap -o name -H -S creation -r "$local_ds" | head -n 1 | cut -d'@' -f2)
    # If in dry-run, check virtuals too
    if [[ "$DRY_RUN" == true ]]; then
        if [[ -n "$VIRTUAL_SNAPS_INCOMING" ]]; then
            # Use the first one from the incoming list as it's the "newest" from upstream
            LATEST_SNAP="${VIRTUAL_SNAPS_INCOMING%%,*}"
        fi
    fi
fi

# 2. Replication & Audit
# 2. Replication & Audit
REPLICATION_SUCCESS=false
HAD_SPLIT_BRAIN=false
hop_idx=0
while [[ $hop_idx -lt ${#NODES_REMAINING[@]} ]]; do
    hop_node="${NODES_REMAINING[$hop_idx]}"
    hop_idx=$((hop_idx + 1))
    
    hop_fqdn=$(resolve_node_fqdn "$hop_node" "$raw_dataset")
    hop_user=$(resolve_node_user "$hop_node" "$raw_dataset")
    HOP_TARGET="${hop_user}@${hop_fqdn}"
    
    echo -e "${CHAIN_PREFIX}  ${C_CYAN}🔍 Checking connectivity to $hop_node ($hop_fqdn)...${C_RESET}"
    NEXT_HOP_POOL=$(resolve_node_pool "$hop_node" "$raw_dataset")
    if [[ $? -eq 255 ]]; then
        if [[ "$REPL_POLICY" == "resilience" ]]; then
            echo -e "${CHAIN_PREFIX}  ${C_YELLOW}⚠️  WARNING:${C_RESET} Node $hop_node is unreachable (Pre-flight). Skipping due to policy=resilience..."
            continue
        else
            die "Node $hop_node is unreachable (Pre-flight). Aborting due to policy=fail."
        fi
    fi
    
    echo -e "${CHAIN_PREFIX}  ${C_CYAN}🚀 Attempting replication:${C_RESET} $local_ds -> $HOP_TARGET (Pool: $NEXT_HOP_POOL)..."
    zfsbud_opts=""
    if [[ "$initial_send" == true ]]; then zfsbud_opts="-i"; fi
    if [[ "$DRY_RUN" == true ]]; then zfsbud_opts="${zfsbud_opts} -d"; fi
    
    TRANSFER_DONE=false
    zfsbud_core $zfsbud_opts -s "$NEXT_HOP_POOL" -e "ssh $HOP_TARGET" -v "$local_ds"
    ZBUD_STATUS=$?

    if [[ $ZBUD_STATUS -eq 0 ]]; then
        echo -e "${CHAIN_PREFIX}  ${C_GREEN}✅ Replication to $HOP_TARGET successful.${C_RESET}"
        TRANSFER_DONE=true
    elif [[ $ZBUD_STATUS -eq 2 ]]; then
        HAD_SPLIT_BRAIN=true
        
        # Read the HINT file generated by zfs-transfer if available
        if [[ -f "/tmp/zfs-replication.hint" ]]; then
            SPLIT_BRAIN_HINT=$(cat "/tmp/zfs-replication.hint")
            rm -f "/tmp/zfs-replication.hint"
        fi
        
        if [[ "$REPL_POLICY" == "resilience" ]]; then
            if [[ "$hop_node" == "${NODES_REMAINING[-1]}" ]]; then
                [[ -n "$SPLIT_BRAIN_HINT" && "$CASCADED" == true ]] && echo "HINT_EXPORT:$SPLIT_BRAIN_HINT"
                die "${C_RED}🚨 FATAL:${C_RESET} Split-Brain detected on Sink node $hop_node. Aborting replication branch." 2
            fi
            echo -e "${CHAIN_PREFIX}  ${C_RED}🚨 FATAL:${C_RESET} Split-Brain detected on $hop_node. Skipping due to policy=resilience..."
            [[ -n "$SPLIT_BRAIN_HINT" && "$CASCADED" == true ]] && echo "HINT_EXPORT:$SPLIT_BRAIN_HINT"
            TRANSFER_DONE=false
            continue
        else
            [[ -n "$SPLIT_BRAIN_HINT" && "$CASCADED" == true ]] && echo "HINT_EXPORT:$SPLIT_BRAIN_HINT"
            die "${C_RED}🚨 FATAL:${C_RESET} Split-Brain detected on $hop_node. Aborting entire replication job for safety." 2
        fi
    elif [[ $ZBUD_STATUS -eq 3 ]]; then
        if [[ "$REPL_POLICY" == "resilience" ]]; then
            if [[ "$hop_node" == "${NODES_REMAINING[-1]}" ]]; then
                die "${C_RED}🚨 FATAL:${C_RESET} Destination $hop_node has newer snapshots and Force is disabled. Aborting replication branch." 3
            fi
            echo -e "${CHAIN_PREFIX}  ${C_RED}🚨 FATAL:${C_RESET} Destination $hop_node has newer snapshots and Force is disabled. Skipping due to policy=resilience..."
            TRANSFER_DONE=false
            continue
        else
            die "${C_RED}🚨 FATAL:${C_RESET} Destination $hop_node has newer snapshots and Force is disabled. Aborting entire replication job." 3
        fi
    else
        echo -e "${CHAIN_PREFIX}  ${C_YELLOW}⚠️  WARNING:${C_RESET} Local replication to $hop_node failed. Searching chain for a better donor..."
        
        if [[ "$IS_DONOR" == true ]]; then
            echo -e "${CHAIN_PREFIX}  ${C_RED}❌ ERROR:${C_RESET} Already acting as donor, skipping recursive discovery."
            DONOR_NODE=""
        else
            DONOR_NODE=$(find_best_donor "$hop_node" "$raw_dataset")
        fi

        if [[ -n "$DONOR_NODE" ]]; then
            donor_fqdn=$(resolve_node_fqdn "$DONOR_NODE" "$raw_dataset")
            donor_user=$(resolve_node_user "$DONOR_NODE" "$raw_dataset")
            donor_target="${donor_user}@${donor_fqdn}"

            echo -e "${CHAIN_PREFIX}  ${C_GREEN}✅ SUCCESS:${C_RESET} Found donor peer '$DONOR_NODE' ($donor_fqdn). Delegating healing of '$hop_node'..."
            if ssh "$donor_target" "$ZEPLICATOR_CMD $raw_dataset $label $keep_fallback --alias $DONOR_NODE --target $hop_node --donor"; then
                echo -e "${CHAIN_PREFIX}  ${C_GREEN}✅ Delegated replication from $DONOR_NODE to $hop_node successful.${C_RESET}"
                
                # RETRY local replication now that common ground should exist
                echo -e "${CHAIN_PREFIX}  ${C_YELLOW}🔄 Retrying local replication to $hop_node...${C_RESET}"
                if zfsbud_core $zfsbud_opts -s "$NEXT_HOP_POOL" -e "ssh $HOP_TARGET" -v "$local_ds"; then
                    echo -e "${CHAIN_PREFIX}  ${C_GREEN}✅ Local replication retry successful.${C_RESET}"
                    TRANSFER_DONE=true
                else
                    echo -e "${CHAIN_PREFIX}  ${C_RED}❌ ERROR:${C_RESET} Local replication retry failed after donor healing."
                fi
            else
                echo -e "${CHAIN_PREFIX}  ${C_RED}❌ ERROR:${C_RESET} Delegated replication from $DONOR_NODE failed."
            fi
        else
            echo -e "${CHAIN_PREFIX}  ${C_RED}❌ ERROR:${C_RESET} No suitable donor found for $hop_node."
        fi
    fi

    if [[ "$TRANSFER_DONE" == false && "$REPL_POLICY" == "fail" ]]; then
        die "Replication to $hop_node failed and no alternative donors succeeded. Aborting due to policy=fail."
    fi

    if [[ "$TRANSFER_DONE" == true ]]; then
        REPLICATION_SUCCESS=true
        
        if [[ "$initial_send" == true ]]; then
            send_smtp_alert "info" "SUCCESS: Initial replication of $local_ds completed successfully to $hop_node ($HOP_TARGET)."
        fi
        
        CASCADE_VERIFIED=false
        if [[ "$PROMOTE" == false && "$IS_DONOR" == false ]]; then
            echo -e "${CHAIN_PREFIX}  ${C_BLUE}🔗${C_RESET} Cascading: triggering downstream chain for $local_ds on $HOP_TARGET"
            casc_opts="--alias $hop_node"
            if [[ "$initial_send" == true ]]; then casc_opts+=" --initial"; fi
            if [[ "$DRY_RUN" == true ]]; then casc_opts+=" --dry-run"; fi
            PROPS_ARG=$(get_repl_props_encoded "$local_ds")
            
            # Internal list of what arrived here (including virtual snaps)
            MY_ARRIVED=""
            if [[ "$PROMOTE" == true || "$CASCADED" == true ]]; then
                MY_ARRIVED=$(zfs list -t snap -o name -H -S creation -r "$local_ds" | cut -d'@' -f2 | xargs | tr ' ' ',')
            else
                MY_ARRIVED=$(zfs list -t snap -o name -H -S creation -r "$local_ds" | grep "@.*$label" | cut -d'@' -f2 | xargs | tr ' ' ',')
            fi
            
            if [[ "$DRY_RUN" == true ]]; then
                [[ -n "$VIRTUAL_SNAPS_INCOMING" ]] && MY_ARRIVED="${MY_ARRIVED},${VIRTUAL_SNAPS_INCOMING}"
                [[ -n "$VIRTUAL_SNAP_CREATED" ]] && MY_ARRIVED="${MY_ARRIVED},${VIRTUAL_SNAP_CREATED}"
                # Clean up commas
                MY_ARRIVED=$(echo "$MY_ARRIVED" | sed 's/,,*/,/g' | sed 's/^,//;s/,$//')
            fi

            # We pass the prefix to maintain the visual tree across SSH hops
            DOWNSTREAM_OUT=$(timeout "$((REPL_TIMEOUT + 5))" ssh -o ConnectTimeout="$REPL_SSH_TIMEOUT" "$HOP_TARGET" "export CHAIN_PREFIX=\"${CHAIN_PREFIX}\"; $ZEPLICATOR_CMD $raw_dataset $label $keep_fallback $casc_opts --sync-props $PROPS_ARG --snap-list \"$MY_ARRIVED\" --cascaded" 2>&1)
            SSH_STATUS=$?
            
            # Extract HINT_EXPORT if present and remove it from standard output
            DOWNSTREAM_HINT=$(echo "$DOWNSTREAM_OUT" | grep "^HINT_EXPORT:" | sed 's/^HINT_EXPORT://')
            if [[ -n "$DOWNSTREAM_HINT" ]]; then
                echo "$DOWNSTREAM_HINT" > /tmp/zfs-replication.hint
                DOWNSTREAM_OUT=$(echo "$DOWNSTREAM_OUT" | grep -v "^HINT_EXPORT:")
            fi

            if [[ $SSH_STATUS -eq 2 ]]; then
                HAD_SPLIT_BRAIN=true
                echo "$DOWNSTREAM_OUT" | grep -v "^SENT_LIST:"
                if [[ "$REPL_POLICY" == "resilience" ]]; then
                    echo "${CHAIN_PREFIX}  ⚠️  WARNING: Split-Brain detected downstream from $hop_node. Skipping affected downstream nodes due to policy=resilience..."
                    # SKIP all nodes that were supposed to be handled by this hop
                    # In a linear chain, these are all remaining nodes in the REPL_CHAIN after hop_node
                    # But we only skip nodes that are already in OUR NODES_REMAINING list.
                    # Since NODES_REMAINING is sorted, we just skip until the end of the chain.
                    # If we had branching, we'd need more complex logic.
                    break 
                else
                    die "🚨 FATAL: Split-Brain detected downstream from $hop_node. Aborting entire replication job." 2
                fi
            fi

            echo "$DOWNSTREAM_OUT" | grep -v "^SENT_LIST:"

            CASCADE_VERIFIED=false
            if [[ $SSH_STATUS -eq 0 ]]; then
                ARRIVED_LIST=$(echo "$DOWNSTREAM_OUT" | grep "^SENT_LIST:" | cut -d':' -f2)
                
                if [[ -n "$LATEST_SNAP" && ",$ARRIVED_LIST," == *",$LATEST_SNAP,"* ]]; then
                    echo -e "${CHAIN_PREFIX}  ${C_GREEN}✅ VERIFICATION SUCCESS:${C_RESET} Snapshot $LATEST_SNAP confirmed reaching a sink node."
                    CASCADE_VERIFIED=true
                else
                    echo -e "${CHAIN_PREFIX}  ${C_YELLOW}⚠️  WARNING:${C_RESET} Verification FAILED. Snapshot $LATEST_SNAP not confirmed at end of chain, but transfer to $hop_node succeeded."
                fi
            else
                echo -e "${CHAIN_PREFIX}  ${C_YELLOW}⚠️  WARNING:${C_RESET} Downstream cascade from $hop_node failed (Code: $SSH_STATUS)."
            fi
        else
            # If donor run or dry run, we consider the local transfer as enough for "success" of this hop
            CASCADE_VERIFIED=true
        fi

        if [[ "$CASCADE_VERIFIED" == true ]]; then
            REPLICATION_SUCCESS=true
            break
        elif [[ "$REPL_POLICY" == "fail" ]]; then
            die "Downstream verification/cascade failed for $hop_node. Aborting due to policy=fail."
        else
            echo "${CHAIN_PREFIX}  ⚠️  Continuing to next hop in chain due to policy=resilience..."
            REPLICATION_SUCCESS=true # We still count the local transfer as a partial success for shipped marking
        fi
    else
        echo "${CHAIN_PREFIX}  ❌ ERROR: Replication to $hop_node failed. Skipping to next available node in chain..."
    fi
done

if [[ "$REPLICATION_SUCCESS" == true ]]; then
    if [[ "$DRY_RUN" == true ]]; then
        echo "${CHAIN_PREFIX}  🏷️  [DRY RUN] Would mark local snapshots ($local_ds) as shipped..."
    else
        echo "${CHAIN_PREFIX}  🏷️  Marking local snapshots ($local_ds) as shipped..."
        zfs list -t snap -o name -H -r "$local_ds" | grep "@.*$label" | \
        while read s; do
            zfs set zep:shipped=true "$s"
        done
    fi
    purge_shipped_snapshots "$local_ds" "$label" "$RESOLVED_KEEP"
    
    # Internal state reporting for upstream verification (only needed if NOT the initiating Master)
    if [[ "$IS_MASTER" == false || "$CASCADED" == true ]]; then
        if [[ "$PROMOTE" == true || "$CASCADED" == true ]]; then
            # During promotion or cascade, we might be verifying non-labeled snapshots
            MY_LIST=$(zfs list -t snap -o name -H -S creation -r "$local_ds" | cut -d'@' -f2 | xargs | tr ' ' ',')
        else
            MY_LIST=$(zfs list -t snap -o name -H -S creation -r "$local_ds" | grep "@.*$label" | cut -d'@' -f2 | xargs | tr ' ' ',')
        fi
        
        if [[ "$DRY_RUN" == true ]]; then
            [[ -n "$VIRTUAL_SNAPS_INCOMING" ]] && MY_LIST="${MY_LIST},${VIRTUAL_SNAPS_INCOMING}"
            [[ -n "$VIRTUAL_SNAP_CREATED" ]] && MY_LIST="${MY_LIST},${VIRTUAL_SNAP_CREATED}"
            MY_LIST=$(echo "$MY_LIST" | sed 's/,,*/,/g' | sed 's/^,//;s/,$//')
        fi
        echo "SENT_LIST:$MY_LIST"
    fi
elif [[ ${#NODES_REMAINING[@]} -gt 0 ]]; then
    exit_code=1
    if [[ "$HAD_SPLIT_BRAIN" == true ]]; then exit_code=2; fi
    die "ERR: All downstream replication attempts failed for chain: ${NODES_REMAINING[*]}" $exit_code
else
    if [[ "$IS_DONOR" == true ]]; then
        echo "${CHAIN_PREFIX}  ℹ️  Donor run complete."
    else
        echo "${CHAIN_PREFIX}  🏁 End of chain ($ME). Reporting state."
        
        if [[ "$DRY_RUN" == true ]]; then
            echo "${CHAIN_PREFIX}  🏷️  [DRY RUN] Sink node would mark snapshots ($local_ds) as shipped..."
        else
            echo "${CHAIN_PREFIX}  🏷️  Sink node marking snapshots ($local_ds) as shipped..."
            zfs list -t snap -o name -H -r "$local_ds" | grep "@.*$label" | \
            while read s; do
                zfs set zep:shipped=true "$s"
            done
        fi
        purge_shipped_snapshots "$local_ds" "$label" "$RESOLVED_KEEP"
    fi

    if [[ "$DRY_RUN" == true ]]; then
        # Report combined virtual + real list
        SINK_LIST=$(zfs list -t snap -o name -H -S creation -r "$local_ds" | grep "@.*$label" | cut -d'@' -f2 | xargs | tr ' ' ',')
        [[ -n "$VIRTUAL_SNAPS_INCOMING" ]] && SINK_LIST="${SINK_LIST},${VIRTUAL_SNAPS_INCOMING}"
        [[ -n "$VIRTUAL_SNAP_CREATED" ]] && SINK_LIST="${SINK_LIST},${VIRTUAL_SNAP_CREATED}"
        SINK_LIST=$(echo "$SINK_LIST" | sed 's/,,*/,/g' | sed 's/^,//;s/,$//')
    else
        SINK_LIST=$(zfs list -t snap -o name -H -S creation -r "$local_ds" | grep "@.*$label" | cut -d'@' -f2 | xargs | tr ' ' ',')
    fi
    # Internal state reporting (silenced from user view)
    echo "SENT_LIST:$SINK_LIST"
fi

dry_done=""
[[ "$DRY_RUN" == true ]] && dry_done=" [DRY RUN]"
echo -e "${CHAIN_PREFIX}  ${C_GREEN}✅ Done${C_RESET}${dry_done}: $(date)"
exit 0
