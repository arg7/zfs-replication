#!/bin/bash

# zeplicator - Modular ZFS Replication Manager
# Main orchestrator script

ZEPLICATOR_CMD="$(readlink -f "$0")"
LIB_DIR=$(dirname "$ZEPLICATOR_CMD")

# Phase 1: Source library modules
source "${LIB_DIR}/zfs-common.lib.sh"
source "${LIB_DIR}/zfs-status.lib.sh"
source "${LIB_DIR}/zfs-stats.lib.sh"
source "${LIB_DIR}/zfs-alerts.lib.sh"
source "${LIB_DIR}/zfs-retention.lib.sh"
source "${LIB_DIR}/zfs-transfer.lib.sh"

# Initialize default variables
raw_filesystem=""
label="frequently"
keep_fallback="10"

usage() {
    cat <<EOF
zeplicator - Modular ZFS Replication Manager

Usage:
  $(basename "$0") <filesystem> [label] [keep_fallback] [flags]

Positional Arguments:
  <filesystem>         The ZFS filesystem to replicate (e.g., tank/data).
                    Can be a remote alias if 'zep:node:<alias>:fs' is set.
  [label]           Snapshot label to filter/create (default: frequently).
  [keep_fallback]   Default number of snapshots to keep if not configured (default: 10).

Primary Flags:
  --dry-run         Simulate the entire replication chain without making changes.
                    Mocks snapshot creation, transfers, property sync, and rotation.
  --auto            Automatically resolve latest common snapshot during promotion.
  --promote         Promote the local node to Master in the replication chain.
  --init            Perform an initial replication (uses full stream, mbuffer/zstd).
  --suspend/resume  Suspend or resume replication across the entire chain.
  --config          Enter configuration mode to view/set/clear 'zep:' ZFS properties.
  --status          Probe and display system status for the replication chain.
  --stats           Output raw node statistics for status display (internal).
  --alias <name>    Manually specify the local node alias (overrides hostname detection).

Advanced Flags:
  --mark-only       Only perform rotation/cleanup of already shipped snapshots.
  --rotate          Run snapshot retention rotation for all labels locally (for root cron).
  --destroy-chain   Force a fresh start when promoting if no common ground exists.
  --snap <name>     Specify a literal snapshot name to use for promotion/rollback.
  --apply-props <b> Apply encoded replication properties and exit (internal).
  --target <node>   Point-to-point transfer to a specific node (ignores chain).
  --donor           Run as a donor peer to heal a downstream node.
  --divergence-report <snap>
                    Check a remote dataset for split-brain divergence (internal).
  -y                Assume 'yes' for destructive operations (promotion/rollback).
  --help, -h        Show this help message.

Configuration Mode (--config):
  $(basename "$0") <filesystem> --config [subcommand]

  --list            (Default) List all 'zep:' properties.
  --clear <key>     Remove a specific property (e.g., smtp:port).
  --export <file>   Save all 'zep:' properties to a file.
  --import <file>   Load 'zep:' properties from a file.
  key=value         Set a property. Supports shorthands:
                    'smtp:host=...' expands to 'zep:smtp_host=...'
                    'node:n1:fqdn=...' expands to 'zep:node:n1:fqdn=...'

Configuration Examples:
  Set chain:      zfs set zep:chain=node1,node2,node3 tank/data
  Set retention:  zfs set zep:node:node1:keep:frequently=30 tank/data
  View config:    zeplicator tank/data --config

EOF
    exit 0
}

MARK_ONLY=false
initial_send=false
PROMOTE=false
APPLY_PROPS=""
CASCADED=false
SUSPEND=false
RESUME=false
AUTO=false
DRY_RUN=false
VIRTUAL_SNAPS_INCOMING=""
VIRTUAL_SNAP_CREATED=""
DESTROY_CHAIN=false
YES=false
PROMOTE_SNAP=""
sync_props_data=""
TARGET_NODE=""
IS_DONOR=false
CONFIG_MODE=false
config_args=()
STATUS_MODE=false
STATS_MODE=false
ROTATE_MODE=false

DIV_MODE=false
DIV_COMMON=""

CLI_ALIAS=""
ORIGINAL_ARGS="$@"

# Parse arguments
positional_args=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        --help|-h) usage ;;
        --alias) CLI_ALIAS="$2"; shift 2 ;;
        --mark-only) MARK_ONLY=true; shift ;;
        --init) initial_send=true; shift ;;
        -bw) export ZEP_BW="true"; shift ;;
        --force-color) export ZEP_FORCE_COLOR="true"; shift ;;
        --promote) PROMOTE=true; shift ;;
        --suspend) SUSPEND=true; shift ;;
        --resume) RESUME=true; shift ;;
        --cascaded) CASCADED=true; shift ;;
        --auto) AUTO=true; shift ;;
        --destroy-chain) DESTROY_CHAIN=true; shift ;;
        -y) YES=true; shift ;;
        --snap) PROMOTE_SNAP="$2"; shift 2 ;;
        --apply-props) APPLY_PROPS="$2"; shift 2 ;;
        --sync-props) sync_props_data="$2"; shift 2 ;;
        --target) TARGET_NODE="$2"; shift 2 ;;
        --donor) IS_DONOR=true; shift ;;
        --dry-run) DRY_RUN=true; shift ;;
        --snap-list) VIRTUAL_SNAPS_INCOMING="$2"; shift 2 ;;
        --status) STATUS_MODE=true; shift ;;
        --stats) STATS_MODE=true; shift ;;
        --rotate) ROTATE_MODE=true; shift ;;
        --show-configured-only) STATUS_CONFIGURED_ONLY=true; shift ;;
        --divergence-report) DIV_MODE=true; DIV_COMMON="$2"; shift 2 ;;
        --config) 
            CONFIG_MODE=true
            shift
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --list|--clear|--export|--import|--all) config_args+=("$1"); shift ;;
                    -*) break ;; # Next main flag
                    *) config_args+=("$1"); shift ;;
                esac
            done
            ;;
        -*) echo "❌ ERROR: Unknown flag: $1" >&2; echo "Run '$(basename "$0") --help' for usage." >&2; exit 1 ;;
        *) positional_args+=("$1"); shift ;; # Collect positional arguments
    esac
done

# Re-initialize colors now that flags like -bw and --force-color might be set
init_colors

# Assign positional arguments
if [[ ${#positional_args[@]} -gt 0 ]]; then raw_filesystem="${positional_args[0]}"; fi
if [[ ${#positional_args[@]} -gt 1 ]]; then label="${positional_args[1]}"; fi
if [[ ${#positional_args[@]} -gt 2 ]]; then keep_fallback="${positional_args[2]}"; fi

# Set log command tag for per-mode log file names
if [[ "$STATS_MODE" == true ]]; then REPL_LOG_CMD="stats"
elif [[ "$STATUS_MODE" == true ]]; then REPL_LOG_CMD="status"
elif [[ "$ROTATE_MODE" == true ]]; then REPL_LOG_CMD="rotate"
elif [[ "$CONFIG_MODE" == true ]]; then REPL_LOG_CMD="config"
elif [[ "$DIV_MODE" == true ]]; then REPL_LOG_CMD="diverge"
else REPL_LOG_CMD="replicate"
fi

trap 'log_message "INFO: exit_code=$?"' EXIT
log_message "INFO: start: $0 $ORIGINAL_ARGS"

# --- Pre-flight argument validation ---
validate_args() {
    local errors=()

    # 0. Flag dependency checks (before anything else)
    if [[ "$DESTROY_CHAIN" == true && "$PROMOTE" != true ]]; then
        errors+=("ERR: --destroy-chain requires --promote")
    fi
    if [[ -n "$PROMOTE_SNAP" && "$PROMOTE" != true ]]; then
        errors+=("ERR: --snap requires --promote")
    fi
    if [[ "$SUSPEND" == true && "$RESUME" == true ]]; then
        errors+=("ERR: --suspend and --resume are mutually exclusive")
    fi
    if [[ "$initial_send" == true && "$PROMOTE" == true ]]; then
        errors+=("ERR: --init and --promote are mutually exclusive")
    fi
    if [[ "$PROMOTE" == true && "$AUTO" != true && -z "$PROMOTE_SNAP" && "$DESTROY_CHAIN" != true ]]; then
        errors+=("ERR: --promote requires one of: --auto, --snap <name>, or --destroy-chain")
    fi

    # 1. Filesystem required (except for status/stats/config)
    if [[ "$STATUS_MODE" != true && "$STATS_MODE" != true && "$CONFIG_MODE" != true ]]; then
        if [[ -z "$raw_filesystem" ]]; then
            # Only show usage if there are no other errors
            if [[ ${#errors[@]} -eq 0 ]]; then
                usage
            fi
        fi
    fi

    # 2. Filesystem must exist as a ZFS dataset
    if [[ -n "$raw_filesystem" ]]; then
        if ! zfs list "$raw_filesystem" >/dev/null 2>&1; then
            errors+=("ERR: Filesystem '$raw_filesystem' does not exist or is not a valid ZFS dataset")
        fi
    fi

    # 2. If --alias is provided, it must be a valid node in the chain
    if [[ -n "$CLI_ALIAS" && -n "$raw_filesystem" ]]; then
        local chain=$(zfs get -H -o value zep:chain "$raw_filesystem" 2>/dev/null)
        if [[ -n "$chain" && "$chain" != "-" ]]; then
            local found=false
            IFS=',' read -ra chain_nodes <<< "$chain"
            for n in "${chain_nodes[@]}"; do
                [[ "$n" == "$CLI_ALIAS" ]] && found=true && break
            done
            if [[ "$found" != true ]]; then
                errors+=("ERR: Alias '$CLI_ALIAS' is not a member of chain '$chain'. Valid nodes: $(IFS=,; echo "${chain_nodes[*]}")")
            fi
        fi
    fi

    # 4. --auto with --promote requires a valid chain
    if [[ "$PROMOTE" == true && "$AUTO" == true && -n "$raw_filesystem" ]]; then
        local chain=$(zfs get -H -o value zep:chain "$raw_filesystem" 2>/dev/null)
        if [[ -z "$chain" || "$chain" == "-" ]]; then
            errors+=("ERR: Cannot promote — no zep:chain configured on '$raw_filesystem'")
        fi
    fi

    if [[ ${#errors[@]} -gt 0 ]]; then
        echo -e "${C_RED}❌ ERROR:${C_RESET} Invalid arguments:"
        for err in "${errors[@]}"; do
            echo "  - $err"
        done
        echo ""
        echo -e "${C_BOLD}Run '$(basename "$0") --help' for usage information.${C_RESET}"
        exit 1
    fi
}

validate_args
# --- End pre-flight validation ---

# --- Divergence report mode (internal) ---
if [[ "$DIV_MODE" == true ]]; then
    if [[ -z "$raw_filesystem" || -z "$DIV_COMMON" ]]; then
        echo "usage: zep <dataset> --divergence-report <common_snapshot>" >&2
        exit 1
    fi
    # Accept either "snap_name" or "dataset@snap_name" — strip the dataset@ prefix if present
    snap_only="${DIV_COMMON##*@}"
    divergence_report "$raw_filesystem" "$snap_only"
    exit $?
fi

# Cache ZFS properties early — before any get_zfs_prop calls
cache_zfs_props "$raw_filesystem"

# If we received properties from upstream (e.g., initial sync), seed the cache 
# so we can correctly resolve local_ds and chain info even if the dataset 
# doesn't exist yet or is named differently.
if [[ -n "$sync_props_data" ]]; then
    seed_cache_from_encoded "$raw_filesystem" "$sync_props_data"
fi

# Early local filesystem resolution
my_hostname=$(get_local_alias "$raw_filesystem" "$CLI_ALIAS")

# Resolve local pool name from node-specific property (e.g., zep:node:<alias>:fs=node1-pool/data1)
configured_ds=$(get_zfs_prop "zep:node:${my_hostname}:fs" "$raw_filesystem")

if [[ -n "$configured_ds" && "$configured_ds" != "-" ]]; then
    local_ds="$configured_ds"
else
    # Fallback to legacy or simple pool/ds resolution
    ds_name="${raw_filesystem#*/}"
    configured_pool=$(get_zfs_prop "zep:node:${my_hostname}:fs" "$raw_filesystem")
    if [[ -n "$configured_pool" && "$configured_pool" != "-" ]]; then
        if [[ "$configured_pool" == *"/"* ]]; then
            local_ds="$configured_pool"
        else
            local_ds="${configured_pool}/${ds_name}"
        fi
    else
        # Last resort fallback: use the provided name directly
        local_ds="$raw_filesystem"
    fi
fi

# If we have synced props, also seed the cache for the resolved local_ds
if [[ -n "$sync_props_data" && "$local_ds" != "$raw_filesystem" ]]; then
    seed_cache_from_encoded "$local_ds" "$sync_props_data"
fi

if [[ "$CASCADED" != true ]]; then
    expected_ds=$(get_zfs_prop "zep:node:${my_hostname}:fs" "$raw_filesystem")
    if [[ -n "$expected_ds" && "$expected_ds" != "-" ]]; then
        if [[ ! "$local_ds" =~ ^"$expected_ds" ]]; then
            echo -e "${CHAIN_PREFIX}  ${C_YELLOW}⚠️${C_RESET}  Filesystem $local_ds is not managed by node $my_hostname (configured: $expected_ds)"
            exit 1
        fi
    fi
fi

filesystem=$local_ds # Ensure helper functions use the local path

REPL_SNAP_PREFIX=$(get_snap_prefix "$filesystem")
REPL_DS_SAFE="${filesystem//\//-}"
REPL_TMP_PREFIX="/tmp/${REPL_SNAP_PREFIX}${CLI_ALIAS:-$(hostname)}-${REPL_DS_SAFE}"
REPL_ERR_FILE="${REPL_TMP_PREFIX}-replication.err"
REPL_HINT_FILE="${REPL_TMP_PREFIX}-replication.hint"
REPL_ALERTS_DIR="${REPL_TMP_PREFIX}-repl-alerts"
export REPL_ERR_FILE REPL_HINT_FILE REPL_ALERTS_DIR

# Handle Stats logic (internal: called via ssh by status cmd)
if [[ "$STATS_MODE" == true ]]; then
    cmd_stats "$raw_filesystem"
    exit $?
fi

# Handle Status logic
if [[ "$STATUS_MODE" == true ]]; then
    cmd_status "$raw_filesystem" "$STATUS_CONFIGURED_ONLY"
    exit $?
fi

# Handle Rotation logic (cron-safe: run as root on any node)
if [[ "$ROTATE_MODE" == true ]]; then
    my_hostname=$(get_local_alias "$raw_filesystem" "$CLI_ALIAS")
    local_ds="$raw_filesystem"
    configured_ds=$(get_zfs_prop "zep:node:${my_hostname}:fs" "$raw_filesystem")
    [[ -n "$configured_ds" && "$configured_ds" != "-" ]] && local_ds="$configured_ds"
    filesystem="$local_ds"

    REPL_CHAIN=$(get_zfs_prop "zep:chain" "$filesystem")
    prefix=$(get_snap_prefix "$filesystem")

    # Determine role index for retention resolution
    ME="$my_hostname"
    if [[ -n "$REPL_CHAIN" ]]; then
        IFS=',' read -r -a nodes <<< "$REPL_CHAIN"
        for idx in "${!nodes[@]}"; do
            [[ "${nodes[$idx]}" == "$ME" ]] && { ME_INDEX=$idx; break; }
        done
    fi

    echo -e "${C_CYAN}🔄${C_RESET} Rotation for $filesystem (node: $ME, role: ${ME_INDEX:+$([ $ME_INDEX -eq 0 ] && echo master || ([ $ME_INDEX -eq $((${#nodes[@]} - 1)) ] && echo sink || echo middle))})"

    # Collect labels from snapshots
    declare -A seen_labels
    while read -r snap; do
        [[ -z "$snap" ]] && continue
        label="${snap#${prefix}}"
        label="${label%%-*}"
        [[ -z "$label" ]] && continue
        seen_labels["$label"]=1
    done < <(zfs list -t snap -H -o name -r "$local_ds" 2>/dev/null | grep "@${prefix}" | cut -d'@' -f2)

    if [[ ${#seen_labels[@]} -eq 0 ]]; then
        echo "  No snapshots found with prefix '${prefix}'. Nothing to rotate."
        exit 0
    fi

    for lbl in "${!seen_labels[@]}"; do
        keep=$(resolve_retention "$local_ds" "$lbl" "$keep_fallback")
        purge_shipped_snapshots "$local_ds" "$lbl" "$keep"
    done

    echo -e "${C_GREEN}✅${C_RESET} Rotation complete."
    exit 0
fi

# Setup cleanup trap (after stats/status exits, so it doesn't fire for them)
trap cleanup EXIT

# Sync properties to nodes across the entire chain
sync_chain_props() {
    local ds_path=$1
    local target_nodes_ref=$2
    eval "local target_nodes=(\"\${$target_nodes_ref[@]}\")"
    local props_encoded=$(get_repl_props_encoded "$ds_path")
    local props_decoded=$(echo -n "$props_encoded" | base64 -d)
    local unreachable=()

    echo "  ⚙️  Syncing replication properties..."
    for n in "${target_nodes[@]}"; do
        [[ "$n" == "$my_hostname" ]] && continue
        local n_fqdn=$(resolve_node_fqdn "$n" "$raw_filesystem")
        local n_user=$(resolve_node_user "$n" "$raw_filesystem")
        local n_ds=$(resolve_node_filesystem "$n" "$raw_filesystem")
        echo -n "    - $n ($n_fqdn)... "
        
            ssh "${n_user}@${n_fqdn}" "bash -s" <<EOF >/dev/null 2>&1
            # Optimization: Cache ZFS properties for the remote dataset during sync
            ds_safe="\${n_ds//\//-}"
            prefix=\$(zfs get -H -o value zep:snap_prefix "\$n_ds" 2>/dev/null)
            [[ -z "\$prefix" || "\$prefix" == "-" ]] && prefix="zep_"
            # Use remote node name in path for robustness
            export PROP_CACHE_FILE="/tmp/\${prefix}\${n}-prop-cache-\${ds_safe}-\\\$\\\$.txt"
            trap 'rm -f "\$PROP_CACHE_FILE"' EXIT
            zfs get all -H -o property,value "\$n_ds" 2>/dev/null | grep "^zep:" | grep -vE ":(shipped|alias|suspend)\$" > "\$PROP_CACHE_FILE" || true
            IFS=$'\x1e' read -ra props <<< "$props_decoded"
            for p in "\${props[@]}"; do
                [[ -z "\$p" ]] && continue
                k="\${p%%=*}"
                v="\${p#*=}"
                
                # Check cache first
                curr=\$(grep -w "^\$k" "\$PROP_CACHE_FILE" | cut -f2 | head -n 1)
                [[ -z "\$curr" ]] && curr=\$(zfs get -H -o value "\$k" "$n_ds" 2>/dev/null)

                if [[ "\$curr" != "\$v" ]]; then
                    zfs set "\$p" "$n_ds"
                fi
            done
EOF
        if [[ $? -eq 0 ]]; then
            echo "✅"
        else
            echo "❌"
            unreachable+=("$n")
        fi
    done
    
    echo ""
    return ${#unreachable[@]}
}

# Handle Configuration logic
handle_config() {
    local args=("$@")

    expand_shorthand() {
        local k="$1"
        if [[ "$k" != zep:* ]]; then
            if [[ "$k" == smtp:* ]]; then
                echo "zep:smtp_${k#*:}"
            else
                echo "zep:$k"
            fi
        else
            echo "$k"
        fi
    }

    local sync_all=false

    if [[ ${#args[@]} -eq 0 || "${args[0]}" == "--list" ]]; then
        echo "  📋 Current Configuration for $filesystem:"
        zfs get all -H -o property,value "$filesystem" | grep "^zep:" | sed 's/^zep://' | sort | awk -F'\t' '{ printf "      %-30s %s\n", $1, $2 }'
        return
    fi

    local i=0
    while [[ $i -lt ${#args[@]} ]]; do
        local arg="${args[i]}"
        
        if [[ "$arg" == "--all" ]]; then
            sync_all=true
            i=$((i + 1))
            continue
        fi

        if [[ "$arg" == "--export" ]]; then
            local fname="${args[((i+1))]}"
            [[ -z "$fname" || "$fname" == -* ]] && die "Missing filename for --export"
            
            echo "  💾 Exporting configuration to $fname..."
            zfs get all -H -o property,value "$filesystem" | grep "^zep:" | awk -F'\t' '{print $1"="$2}' > "$fname"
            i=$((i + 2))
            continue
        fi

        if [[ "$arg" == "--import" ]]; then
            local fname="${args[((i+1))]}"
            [[ -z "$fname" || ! -f "$fname" ]] && die "Missing or invalid filename for --import"
            
            echo "  📥 Importing configuration from $fname..."
            while IFS= read -r line || [[ -n "$line" ]]; do
                # Trim whitespaces
                line="$(echo "$line" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
                [[ -z "$line" || "$line" == \#* ]] && continue
                
                if [[ "$line" == *"="* ]]; then
                    local key="${line%%=*}"
                    local val="${line#*=}"
                    
                    key=$(expand_shorthand "$key")
                    
                    echo "  ⚙️  Setting $key=$val on $filesystem"
                    zfs set "$key=$val" "$filesystem" || echo "    ⚠️  Failed to set $key"
                fi
            done < "$fname"
            i=$((i + 2))
            continue
        fi

        if [[ "$arg" == "--clear" ]]; then
            local key="${args[((i+1))]}"
            [[ -z "$key" ]] && die "Missing property key to clear"
            
            local full_key=$(expand_shorthand "$key")

            echo "  ⚙️  Clearing $full_key from $filesystem..."
            zfs inherit "$full_key" "$filesystem" || echo "    ⚠️  Failed to clear $full_key"
            i=$((i + 2))
            continue
        fi

        if [[ "$arg" == *"="* ]]; then
            local key="${arg%%=*}"
            local val="${arg#*=}"
            
            local full_key=$(expand_shorthand "$key")
            
            echo "  ⚙️  Setting $full_key=$val on $filesystem"
            zfs set "$full_key"="$val" "$filesystem" || echo "    ⚠️  Failed to set $full_key"
        else
            echo "  ⚠️  Ignoring invalid config argument: $arg (Expected key=value)"
        fi
        i=$((i + 1))
    done

    # Refresh cache before syncing to other nodes
    cache_zfs_props "$filesystem"

    # Only sync to the chain if --all flag was specified
    if [[ "$sync_all" == true ]]; then
        local current_chain=$(get_zfs_prop "zep:chain" "$filesystem")
        if [[ -n "$current_chain" && "$current_chain" != "-" ]]; then
            IFS=',' read -r -a nodes <<< "$current_chain"
            if sync_chain_props "$filesystem" "nodes"; then
                echo "  🎉 SUCCESS: Configuration updated and synced across the chain."
            else
                echo "  ⚠️  PARTIAL SUCCESS: Configuration updated, but some nodes were unreachable during sync."
            fi
        fi
    fi
}

if [[ "$CONFIG_MODE" == true ]]; then
    handle_config "${config_args[@]}"
    exit 0
fi

# Identity & Configuration Discovery
REPL_CHAIN=$(get_zfs_prop "zep:chain" "$local_ds")
REPL_USER=$(get_zfs_prop "zep:user" "$local_ds")
REPL_POLICY=$(get_zfs_prop "zep:policy" "$local_ds")
REPL_SSH_TIMEOUT=$(resolve_ssh_timeout "$local_ds")
REPL_TIMEOUT=$(resolve_proc_timeout "$local_ds")
[[ -z "$REPL_USER" ]] && REPL_USER="root"
[[ -z "$REPL_POLICY" || "$REPL_POLICY" == "-" ]] && REPL_POLICY="fail"

# Handle Suspend/Resume logic
if [[ "$SUSPEND" == true || "$RESUME" == true ]]; then
    ACTION="SUSPENDED"
    VAL="true"
    if [[ "$RESUME" == true ]]; then 
        ACTION="RESUMED"
        VAL="false"
    fi

    echo "  🛡️  ${ACTION} replication for $raw_filesystem..."
    
    CURRENT_CHAIN=$(get_zfs_prop "zep:chain" "$local_ds")
    if [[ -z "$CURRENT_CHAIN" ]]; then
        die "ERR: Cannot ${ACTION}, no existing zep:chain found on $local_ds. Please run from a configured node."
    fi

    IFS=',' read -r -a nodes <<< "$CURRENT_CHAIN"
    for n in "${nodes[@]}"; do
        n_fqdn=$(resolve_node_fqdn "$n" "$local_ds")
        n_user=$(resolve_node_user "$n" "$local_ds")
        n_ds=$(resolve_node_filesystem "$n" "$local_ds")
        echo "    ⏳ Setting zep:suspend=$VAL on $n ($n_fqdn)..."
        ssh "${n_user}@${n_fqdn}" "zfs set zep:suspend=$VAL ${n_ds}" || echo -e "  ${C_YELLOW}⚠️  WARNING:${C_RESET} Failed to set property on $n"
    done
    
    send_smtp_alert "info" "NOTICE: ZFS Replication has been ${ACTION} for filesystem $raw_filesystem on $my_hostname. Master node: ${nodes[0]}. New state: zep:suspend=$VAL"
    exit 0
fi

# Handle --apply-props (used by promotion to propagate chain config)
if [[ -n "$APPLY_PROPS" ]]; then
    apply_repl_props "$local_ds" "$APPLY_PROPS" >/dev/null 2>&1
    exit 0
fi

# Handle Promotion logic
if [[ "$PROMOTE" == true ]]; then
    echo "  🚀 Promoting $my_hostname to Master..."
    
    CURRENT_CHAIN=$(get_zfs_prop "zep:chain" "$local_ds")
    if [[ -z "$CURRENT_CHAIN" ]]; then die "ERR: Cannot promote, no existing zep:chain found on $local_ds"; fi

    IFS=',' read -r -a nodes <<< "$CURRENT_CHAIN"
    NEW_NODES=("$my_hostname")
    for n in "${nodes[@]}"; do
        if [[ "$n" != "$my_hostname" ]]; then
            NEW_NODES+=("$n")
        fi
    done
    NEW_CHAIN=$(IFS=','; echo "${NEW_NODES[*]}")
    
    if [[ "$CURRENT_CHAIN" == "$NEW_CHAIN" ]]; then
        echo "  $my_hostname is already Master in local config."
        exit 0
    fi

    if [[ "$AUTO" == true || -n "$PROMOTE_SNAP" || "$DESTROY_CHAIN" == true ]]; then
        TARGET_SNAP=""
        declare -a REACHABLE_NODES=()
        declare -a UNREACHABLE_NODES=()

        if [[ -n "$PROMOTE_SNAP" ]]; then
            TARGET_SNAP="$PROMOTE_SNAP"
            echo "  🔍 Verifying snapshot @$TARGET_SNAP consistency..."
            for n in "${NEW_NODES[@]}"; do
                echo -n "    - $n... "
                local_ds_target=$(resolve_node_filesystem "$n" "$raw_filesystem")
                local_fqdn=$(resolve_node_fqdn "$n" "$raw_filesystem")
                local_user=$(resolve_node_user "$n" "$raw_filesystem")

                # Validate node configuration before attempting verification
                if [[ "$local_fqdn" == "-" || -z "$local_fqdn" ]]; then
                    echo "❌"
                    UNREACHABLE_NODES+=("$n")
                    echo ""
                    echo "      ⚠️  WARNING: No FQDN configured for node '$n'. Set zep:node:${n}:fqdn"
                    continue
                fi
                if [[ "$local_ds_target" == "-" || -z "$local_ds_target" ]]; then
                    echo "❌"
                    UNREACHABLE_NODES+=("$n")
                    echo ""
                    echo "      ⚠️  WARNING: No filesystem configured for node '$n'. Set zep:node:${n}:fs"
                    continue
                fi

                g=$(ssh "${local_user}@${local_fqdn}" "zfs get -H -o value guid ${local_ds_target}@$TARGET_SNAP" 2>/dev/null)
                if [[ -n "$g" && "$g" != "-" ]]; then
                    echo "✅"
                    REACHABLE_NODES+=("$n")
                else
                    echo "❌"
                    UNREACHABLE_NODES+=("$n")
                fi
            done
            [[ -z "${REACHABLE_NODES[0]}" ]] && die "ERR: Snapshot @$TARGET_SNAP not found on any reachable node."
        else
            echo "  🔍 Auto-discovering latest common snapshot..."
            tmp_common="/tmp/${REPL_SNAP_PREFIX}${my_hostname}-common-snaps.$$"
            f_node_flag=true

            for n in "${NEW_NODES[@]}"; do
                echo -n "    - Querying $n... "
                local_ds_target=$(resolve_node_filesystem "$n" "$raw_filesystem")
                local_fqdn=$(resolve_node_fqdn "$n" "$raw_filesystem")
                local_user=$(resolve_node_user "$n" "$raw_filesystem")

                # Validate node configuration before attempting query
                if [[ "$local_fqdn" == "-" || -z "$local_fqdn" ]]; then
                    echo "❌"
                    UNREACHABLE_NODES+=("$n")
                    echo "      ⚠️  WARNING: No FQDN configured for node '$n'. Set zep:node:${n}:fqdn"
                    continue
                fi
                if [[ "$local_ds_target" == "-" || -z "$local_ds_target" ]]; then
                    echo "❌"
                    UNREACHABLE_NODES+=("$n")
                    echo "      ⚠️  WARNING: No filesystem configured for node '$n'. Set zep:node:${n}:fs"
                    continue
                fi

                node_target="${local_user}@${local_fqdn}"

                node_tmp="/tmp/${REPL_SNAP_PREFIX}${my_hostname}-node-snaps.$$"
                query_ok=false
                if [[ "$n" == "$my_hostname" ]]; then
                    zfs list -t snap -H -o guid -r "${local_ds_target}" 2>/dev/null > "$node_tmp" && query_ok=true
                else
                    if timeout "$REPL_SSH_TIMEOUT" ssh -o ConnectTimeout="$REPL_SSH_TIMEOUT" -o BatchMode=yes "$node_target" "zfs list -t snap -H -o guid -r ${local_ds_target}" 2>/dev/null > "$node_tmp"; then
                        query_ok=true
                    fi
                fi

                if [[ "$query_ok" == true ]]; then
                    echo "✅"
                    REACHABLE_NODES+=("$n")
                    if [[ "$f_node_flag" == true ]]; then
                        mv "$node_tmp" "$tmp_common"
                        f_node_flag=false
                    else
                        grep -Fxf "$tmp_common" "$node_tmp" > "${tmp_common}.new"
                        mv "${tmp_common}.new" "$tmp_common"
                        rm -f "$node_tmp"
                    fi
                else
                    echo "❌"
                    UNREACHABLE_NODES+=("$n")
                    rm -f "$node_tmp"
                fi
                [[ ! -s "$tmp_common" && "$f_node_flag" == false ]] && break
            done

            if [[ -s "$tmp_common" ]]; then
                TARGET_GUID=""
                while read -r local_guid; do
                    if grep -qx "$local_guid" "$tmp_common"; then
                        TARGET_GUID="$local_guid"
                    fi
                done < <(zfs list -t snap -H -o guid -r "$local_ds")

                if [[ -n "$TARGET_GUID" ]]; then
                    local_info=$(zfs list -t snap -H -o name,guid -r "$local_ds" | grep "$TARGET_GUID" | head -n 1)
                    TARGET_SNAP=$(echo "$local_info" | awk '{print $1}' | cut -d'@' -f2)
                    target_guid=$(echo "$local_info" | awk '{print $2}')
                    echo "  🔗 Found latest common snapshot: @$TARGET_SNAP"
                else
                    die "ERR: Could not resolve any common snapshot GUID locally."
                fi
            fi
            rm -f "$tmp_common"
        fi

        if [[ "$DESTROY_CHAIN" == true && -n "$TARGET_SNAP" ]]; then
            echo "ABORT: Common snapshot @$TARGET_SNAP found! Destruction is NOT necessary."
            exit 1
        fi
        
        if [[ "$AUTO" == true || -n "$PROMOTE_SNAP" ]]; then
            if [[ -z "$TARGET_SNAP" ]]; then
                die "ERR: Could not find a common snapshot across all nodes. Use --destroy-chain if you want to start fresh."
            fi

            if [[ "$YES" != true ]]; then
                echo -n "Are you sure you want to rollback ALL nodes in the chain to @$TARGET_SNAP? (y/N): "
                read -r resp
                if [[ "$resp" != "y" ]]; then die "Aborted by user."; fi
            fi

            echo "  🔄 Rolling back reachable nodes to @$TARGET_SNAP..."
            for n in "${REACHABLE_NODES[@]}"; do
                echo -n "    - $n... "
                local_ds_target=$(resolve_node_filesystem "$n" "$raw_filesystem")
                local_fqdn=$(resolve_node_fqdn "$n" "$raw_filesystem")
                local_user=$(resolve_node_user "$n" "$raw_filesystem")
                if [[ "$n" == "$my_hostname" ]]; then
                    zfs rollback -r "${local_ds_target}@$TARGET_SNAP" && echo "✅" || die "ERR: Local rollback failed"
                else
                    ssh "${local_user}@${local_fqdn}" "zfs rollback -r ${local_ds_target}@$TARGET_SNAP" && echo "✅" || echo "❌"
                fi
            done
            
            echo "  ✨ Updating local chain configuration..."
            zfs set zep:chain="$NEW_CHAIN" "$local_ds"
            REPL_CHAIN="$NEW_CHAIN"
            send_smtp_alert "info" "NOTICE: Node $my_hostname has been PROMOTED to Master for filesystem $raw_filesystem. New chain: $NEW_CHAIN"
            # Refresh cache so prop encoding picks up the new chain
            cache_zfs_props "$local_ds"

            # Propagate the new chain to all downstream nodes in order
            _props_encoded=$(get_repl_props_encoded "$local_ds")
            echo "  🔄 Propagating new chain configuration to downstream nodes..."
            _unreachable_count=0
            for _n in "${NEW_NODES[@]}"; do
                [[ "$_n" == "$my_hostname" ]] && continue
                _n_fqdn=$(resolve_node_fqdn "$_n" "$raw_filesystem")
                _n_user=$(resolve_node_user "$_n" "$raw_filesystem")
                _n_ds=$(resolve_node_filesystem "$_n" "$raw_filesystem")

                # Validate node configuration before attempting propagation
                if [[ "$_n_fqdn" == "-" || -z "$_n_fqdn" ]]; then
                    echo "❌"
                    echo "      ⚠️  WARNING: No FQDN configured for node '$_n'. Skipping."
                    _unreachable_count=$((_unreachable_count + 1))
                    continue
                fi
                if [[ "$_n_ds" == "-" || -z "$_n_ds" ]]; then
                    echo "❌"
                    echo "      ⚠️  WARNING: No filesystem configured for node '$_n'. Skipping."
                    _unreachable_count=$((_unreachable_count + 1))
                    continue
                fi

                echo -n "    - $_n ($_n_fqdn)... "
                _ssh_rc=0
                ssh -o ConnectTimeout="$REPL_SSH_TIMEOUT" "${_n_user}@${_n_fqdn}" \
                    "$ZEPLICATOR_CMD $raw_filesystem $label $keep_fallback --alias $_n --apply-props $_props_encoded" >/dev/null 2>&1 || _ssh_rc=$?
                if [[ $_ssh_rc -eq 0 ]]; then
                    echo "✅"
                else
                    echo "❌"
                    _unreachable_count=$((_unreachable_count + 1))
                fi
            done

            if [[ $_unreachable_count -eq 0 ]]; then
                echo "  🎉 SUCCESS: Promotion complete! Node $my_hostname is now Master."
            else
                echo "  ⚠️  PARTIAL SUCCESS: Node $my_hostname is Master, but $_unreachable_count node(s) were unreachable during prop sync."
                echo "     Replication will attempt to heal them during the next cycle."
            fi
            exit 0
        else
            # --promote --destroy-chain (no --auto or --snap): set new chain without rollback
            echo "  ✨ Setting new chain configuration without rollback..."
            zfs set zep:chain="$NEW_CHAIN" "$local_ds"
            REPL_CHAIN="$NEW_CHAIN"
            cache_zfs_props "$local_ds"

            _props_encoded=$(get_repl_props_encoded "$local_ds")
            _unreachable_count=0
            for _n in "${NEW_NODES[@]}"; do
                [[ "$_n" == "$my_hostname" ]] && continue
                _n_fqdn=$(resolve_node_fqdn "$_n" "$raw_filesystem")
                _n_user=$(resolve_node_user "$_n" "$raw_filesystem")
                _n_ds=$(resolve_node_filesystem "$_n" "$raw_filesystem")

                # Validate node configuration before attempting propagation
                if [[ "$_n_fqdn" == "-" || -z "$_n_fqdn" ]]; then
                    echo "❌"
                    echo "      ⚠️  WARNING: No FQDN configured for node '$_n'. Skipping."
                    _unreachable_count=$((_unreachable_count + 1))
                    continue
                fi
                if [[ "$_n_ds" == "-" || -z "$_n_ds" ]]; then
                    echo "❌"
                    echo "      ⚠️  WARNING: No filesystem configured for node '$_n'. Skipping."
                    _unreachable_count=$((_unreachable_count + 1))
                    continue
                fi

                echo -n "    - $_n ($_n_fqdn)... "
                _ssh_rc=0
                ssh -o ConnectTimeout="$REPL_SSH_TIMEOUT" "${_n_user}@${_n_fqdn}" \
                    "$ZEPLICATOR_CMD $raw_filesystem $label $keep_fallback --alias $_n --apply-props $_props_encoded" >/dev/null 2>&1 || _ssh_rc=$?
                if [[ $_ssh_rc -eq 0 ]]; then
                    echo "✅"
                else
                    echo "❌"
                    _unreachable_count=$((_unreachable_count + 1))
                fi
            done

            if [[ $_unreachable_count -eq 0 ]]; then
                echo "  🎉 SUCCESS: Promotion complete! Node $my_hostname is now Master."
            else
                echo "  ⚠️  PARTIAL SUCCESS: Node $my_hostname is Master, but $_unreachable_count node(s) unreachable."
            fi
            exit 0
        fi
    fi
fi

# Apply propagated properties
if [[ -n "$sync_props_data" ]]; then
    if zfs list "$local_ds" >/dev/null 2>&1; then
        apply_repl_props "$local_ds" "$sync_props_data"
    else
        echo "INFO: Filesystem $local_ds not found, skipping property sync (likely initial run)."
    fi
fi

ME=$(get_local_alias "$local_ds" "$CLI_ALIAS")
CLI_ALIAS="$ME" # Update global CLI_ALIAS with resolved value for lock file
NEXT_HOP=""
IS_MASTER=false
ME_INDEX=-1
RESOLVED_KEEP=$keep_fallback

if [[ -n "$REPL_CHAIN" ]]; then
    IFS=',' read -r -a nodes <<< "$REPL_CHAIN"
    
    # Pre-flight dependency check (only if --init is set and NOT a cascaded call)
    if [[ "$initial_send" == true && "$CASCADED" == false ]]; then
        echo -e "${CHAIN_PREFIX}  ${C_CYAN}🛠️${C_RESET}  Pre-flight: Checking dependencies (mbuffer, zstd) across all nodes..."
        for n in "${nodes[@]}"; do
            n_fqdn=$(resolve_node_fqdn "$n" "$local_ds")
            n_user=$(resolve_node_user "$n" "$local_ds")
            
            echo -e "${CHAIN_PREFIX}    ${C_CYAN}🔍${C_RESET} Checking $n ($n_fqdn)..."
            if ! timeout "$((REPL_SSH_TIMEOUT + 5))" ssh -o ConnectTimeout="$REPL_SSH_TIMEOUT" -o BatchMode=yes "${n_user}@${n_fqdn}" "which mbuffer >/dev/null && which zstd >/dev/null"; then
                die "Missing dependencies (mbuffer or zstd) or connection timeout on node: $n ($n_fqdn). Please install them before proceeding with --init."
            fi
        done
        echo -e "${CHAIN_PREFIX}  ${C_GREEN}✅${C_RESET} All nodes verified."
    fi

    NODES_REMAINING=()
    for i in "${!nodes[@]}"; do
        if [[ "${nodes[i]}" == "$ME" ]]; then
            ME_INDEX=$i
            if [[ $i -eq 0 ]]; then IS_MASTER=true; fi
            for (( j=i+1; j<${#nodes[@]}; j++ )); do
                NODES_REMAINING+=("${nodes[j]}")
            done
            if (( ${#NODES_REMAINING[@]} > 0 )); then
                NEXT_HOP="${REPL_USER}@${NODES_REMAINING[0]}"
            fi
            break
        fi
    done
    [[ $ME_INDEX -eq -1 ]] && die "ERR: Host $ME is not part of the replication chain for $local_ds"
    
    if [[ "$CASCADED" == true ]]; then
        # Running as downstream hop — indent one level deeper than upstream
        CHAIN_PREFIX+="  | "
    else
        CHAIN_PREFIX=""
    fi
    
    dry_flag=""
    [[ "$DRY_RUN" == true ]] && dry_flag=" [DRY RUN]"

    # Validate label has configured retention policies
    validate_label() {
        local lbl=$1
        local ds=$2
        local node_list=("${nodes[@]}")
        local idx=$ME_INDEX
        local local_role
        [[ $idx -eq 0 ]] && local_role="master" || { [[ $idx -eq $((${#node_list[@]}-1)) ]] && local_role="sink" || local_role="middle"; }

        # Check if ANY role has a retention configured for this label
        local found=false
        for r in master middle sink; do
            local v=$(zfs get -H -o value "zep:role:${r}:keep:${lbl}" "$ds" 2>/dev/null)
            if [[ -n "$v" && "$v" != "-" && "$v" =~ ^[0-9]+$ ]]; then
                found=true
                break
            fi
        done

        # Also check node-specific retention
        if [[ "$found" != true ]]; then
            local node_val=$(zfs get -H -o value "zep:node:${ME}:keep:${lbl}" "$ds" 2>/dev/null)
            [[ -n "$node_val" && "$node_val" != "-" && "$node_val" =~ ^[0-9]+$ ]] && found=true
        fi

        if [[ "$found" != true ]]; then
            # Collect available labels for helpful error message
            local available=$(zfs get -H -o property "$ds" 2>/dev/null | grep 'role:.*:keep:' | sed 's/.*role:[a-z]*:keep://' | sort -u | tr '\n' ', ' | sed 's/,$//')
            if [[ -n "$available" ]]; then
                die "ERR: Label '$lbl' has no retention policy configured (checked role:${local_role}). Available labels: $available"
            else
                die "ERR: Label '$lbl' has no retention policy configured. Set zep:role:${local_role}:keep:${lbl} on $ds"
            fi
        fi
    }

    validate_label "$label" "$local_ds"

    dry_flag=""
    [[ "$DRY_RUN" == true ]] && dry_flag=" [DRY RUN]"
    echo -e "${CHAIN_PREFIX}${C_CYAN}🏁${C_RESET} Start${dry_flag}: $(date); Filesystem: $local_ds; Label: $label"

    RESOLVED_KEEP=$(resolve_retention "$local_ds" "$label" "$keep_fallback")
    fi

if [[ -n "$TARGET_NODE" ]]; then
    NODES_REMAINING=("$TARGET_NODE")
    IS_MASTER=true

    # Validate label for point-to-point transfers
    validate_label_p2p() {
        local lbl=$1
        local ds=$2
        local found=false
        for r in master middle sink; do
            local v=$(zfs get -H -o value "zep:role:${r}:keep:${lbl}" "$ds" 2>/dev/null)
            if [[ -n "$v" && "$v" != "-" && "$v" =~ ^[0-9]+$ ]]; then
                found=true
                break
            fi
        done
        if [[ "$found" != true ]]; then
            local node_val=$(zfs get -H -o value "zep:node:${ME}:keep:${lbl}" "$ds" 2>/dev/null)
            [[ -n "$node_val" && "$node_val" != "-" && "$node_val" =~ ^[0-9]+$ ]] && found=true
        fi
        if [[ "$found" != true ]]; then
            local available=$(zfs get -H -o property "$ds" 2>/dev/null | grep 'role:.*:keep:' | sed 's/.*role:[a-z]*:keep://' | sort -u | tr '\n' ', ' | sed 's/,$//')
            if [[ -n "$available" ]]; then
                die "ERR: Label '$lbl' has no retention policy configured. Available labels: $available"
            else
                die "ERR: Label '$lbl' has no retention policy configured."
            fi
        fi
    }

    validate_label_p2p "$label" "$local_ds"

    dry_flag=""
    [[ "$DRY_RUN" == true ]] && dry_flag=" [DRY RUN]"
    echo -e "${CHAIN_PREFIX}${C_CYAN}🏁${C_RESET} Start${dry_flag}: $(date); Filesystem: $local_ds; Label: $label (target: $TARGET_NODE)"
    RESOLVED_KEEP=$(resolve_retention "$local_ds" "$label" "$keep_fallback")
    echo -e "${CHAIN_PREFIX}  ${C_BLUE}🛡️${C_RESET}  Using dynamic retention for $label: $RESOLVED_KEEP"
fi

# --- HEARTBEAT MONITORING LOGIC ---
if [[ "$IS_MASTER" == false ]]; then
    # 1. Check for heartbeat property
    HB_PROP="zep:alert:heartbeat:${label}"
    HB_THRESHOLD_RAW=$(get_zfs_prop "$HB_PROP" "$local_ds")
    
    if [[ "$HB_THRESHOLD_RAW" != "-" ]]; then
        # 2. Parse threshold to seconds
        HB_THRESHOLD_SEC=$(parse_time_to_seconds "$HB_THRESHOLD_RAW")
        
        # 3. Find latest snapshot for label
        LATEST_SNAP_NAME=$(zfs list -t snap -o name -H -S creation -r "$local_ds" | grep "@${REPL_SNAP_PREFIX}${label}-" | head -n 1)
        
        if [[ -n "$LATEST_SNAP_NAME" ]]; then
            # 4. Calculate age in seconds
            SNAP_TIME=$(zfs get -H -o value creation "$LATEST_SNAP_NAME")
            SNAP_EPOCH=$(date -d "$SNAP_TIME" +%s)
            NOW_EPOCH=$(date +%s)
            AGE_SEC=$(( NOW_EPOCH - SNAP_EPOCH ))
            
            # 5. If age exceeds threshold, alert
            if [[ $AGE_SEC -gt $HB_THRESHOLD_SEC ]]; then
                send_smtp_alert "critical" "CRITICAL: Upstream chain silent for label '${label}' on '${local_ds}'. Latest snapshot '${LATEST_SNAP_NAME}' is $((AGE_SEC/60)) minutes old (threshold: ${HB_THRESHOLD_RAW})."
            fi
        fi
    fi
fi
# --- END HEARTBEAT MONITORING ---

if [[ "$IS_MASTER" == false && "$CASCADED" == false && "$PROMOTE" == false && "$MARK_ONLY" == false && -z "$TARGET_NODE" && "$IS_DONOR" == false ]]; then
    echo "${CHAIN_PREFIX}  🛡️  Node $ME is not Master."
    exit 1
fi

if [[ "$IS_MASTER" == true && "$CASCADED" == false && "$PROMOTE" == false && -z "$TARGET_NODE" ]]; then
    SUSPEND_STATE=$(get_zfs_prop "zep:suspend" "$local_ds")
    if [[ "$SUSPEND_STATE" == "true" ]]; then
        echo "${CHAIN_PREFIX}  🛑 Replication is SUSPENDED (zep:suspend=true). Skipping run."
        exit 0
    fi
fi


if [[ "$MARK_ONLY" == true ]]; then
    if [[ "$IS_MASTER" == true ]]; then
        purge_shipped_snapshots "$local_ds" "$label" "$RESOLVED_KEEP"
    fi
    exit 0
fi

filesystem="$local_ds"

# 1. Snapshot creation (Master only)
if [[ "$IS_MASTER" == true && "$CASCADED" == false && "$PROMOTE" == false && -z "$TARGET_NODE" && "$IS_DONOR" == false ]]; then
    timestamp=$(date -u +%Y-%m-%d-%H%M)
    snap_name_base="${REPL_SNAP_PREFIX}${label}-${timestamp}"
    snap_name="${local_ds}@${snap_name_base}"

    if [[ "$DRY_RUN" == true ]]; then
        echo -e "${CHAIN_PREFIX}  ${C_YELLOW}⏳${C_RESET} [DRY RUN] Would create snapshot: $snap_name"
        VIRTUAL_SNAP_CREATED="$snap_name_base"
    elif zfs list -t snap "$snap_name" >/dev/null 2>&1; then
        # Snapshot already exists — make name unique by adding seconds
        timestamp=$(date -u +%Y-%m-%d-%H%M%S)
        snap_name_base="${REPL_SNAP_PREFIX}${label}-${timestamp}"
        snap_name="${local_ds}@${snap_name_base}"
        echo -e "${CHAIN_PREFIX}  ${C_YELLOW}⏳${C_RESET} Creating snapshot: $snap_name (seconds-unique)"
        zfs snapshot "$snap_name" 2>&1 | indent_output
        [[ ${PIPESTATUS[0]} -eq 0 ]] || die "ERR: snapshot creation failed"
    else
        echo -e "${CHAIN_PREFIX}  ${C_YELLOW}⏳${C_RESET} Creating snapshot: $snap_name"
        zfs snapshot "$snap_name" 2>&1 | indent_output
        [[ ${PIPESTATUS[0]} -eq 0 ]] || die "ERR: snapshot creation failed"
    fi
else
    if [[ "$IS_DONOR" == true ]]; then
        echo "${CHAIN_PREFIX}  ℹ️  Node $ME is acting as Donor. Skipping snapshot creation."
    elif [[ -n "$TARGET_NODE" ]]; then
        echo "${CHAIN_PREFIX}  ℹ️  Point-to-point transfer to $TARGET_NODE. Skipping snapshot creation."
    elif [[ "$PROMOTE" == true ]]; then
        echo "${CHAIN_PREFIX}  ℹ️  Promoting chain. Skipping initial snapshot creation."
    else
        echo "${CHAIN_PREFIX}  ℹ️  Not a master host ($ME), skipping snapshot creation."
    fi
fi

check_stuck_job

LATEST_SNAP=$(zfs list -t snap -o name -H -S creation -r "$local_ds" | grep "@${REPL_SNAP_PREFIX}${label}-" | head -n 1 | cut -d'@' -f2)
if [[ "$DRY_RUN" == true && -n "$VIRTUAL_SNAP_CREATED" ]]; then
    LATEST_SNAP="$VIRTUAL_SNAP_CREATED"
fi

# If we are in a cascaded/donor run and still don't have a LATEST_SNAP by label,
# use the literal latest snapshot available to ensure verification logic has something to check.
if [[ -z "$LATEST_SNAP" && ( "$CASCADED" == true || "$IS_DONOR" == true ) ]]; then
    LATEST_SNAP=$(zfs list -t snap -o name -H -S creation -r "$local_ds" | head -n 1 | cut -d'@' -f2)
    # If in dry-run, check virtuals too
    if [[ "$DRY_RUN" == true ]]; then
        if [[ -n "$VIRTUAL_SNAPS_INCOMING" ]]; then
            # Use the first one from the incoming list as it's the "newest" from upstream
            LATEST_SNAP="${VIRTUAL_SNAPS_INCOMING%%,*}"
        fi
    fi
fi

# Check if local dataset has a stale split-brain flag (set by a previous failed send from this node).
# If the script is running, the sysadmin must have resolved the condition.
PRE_REPL_SB=$(zfs get -H -o value zep:error:split-brain "$local_ds" 2>/dev/null)
if [[ "$PRE_REPL_SB" == "true" ]]; then
    zfs inherit zep:error:split-brain "$local_ds" 2>/dev/null
    echo -e "${CHAIN_PREFIX}  ${C_CYAN}ℹ️${C_RESET}  Split-Brain condition resolved on $local_ds. Cleared error flag."
    send_smtp_alert "warning" "NOTICE: Split-Brain condition on $local_ds has been resolved. The error flag has been cleared."
    PRE_REPL_SB="false"
fi

# 2. Replication & Audit
REPLICATION_SUCCESS=false
REPLICATION_PARTIAL=false
HAD_SPLIT_BRAIN=false
hop_idx=0
while [[ $hop_idx -lt ${#NODES_REMAINING[@]} ]]; do
    hop_node="${NODES_REMAINING[$hop_idx]}"
    hop_idx=$((hop_idx + 1))
    
    hop_fqdn=$(resolve_node_fqdn "$hop_node" "$raw_filesystem")
    hop_user=$(resolve_node_user "$hop_node" "$raw_filesystem")
    HOP_TARGET="${hop_user}@${hop_fqdn}"
    NEXT_HOP_POOL=$(resolve_node_pool "$hop_node" "$raw_filesystem")

    remote_ds=$(resolve_node_filesystem "$hop_node" "$raw_filesystem")

    echo -e "${CHAIN_PREFIX}  ${C_CYAN}🚀${C_RESET} Attempting replication: $local_ds -> $HOP_TARGET (Pool: $NEXT_HOP_POOL)..."

    TRANSFER_DONE=false
    if [[ "$DRY_RUN" == true ]]; then
        echo -e "${CHAIN_PREFIX}  ${C_CYAN}⏳${C_RESET} [DRY RUN] Would replicate $local_ds -> $HOP_TARGET"
        ZBUD_STATUS=0
        TRANSFER_DONE=true
    else
        zfsbud_opts=""
        if [[ "$initial_send" == true ]]; then zfsbud_opts="-i"; fi
        zfsbud_core $zfsbud_opts -s "$NEXT_HOP_POOL" -e "ssh $HOP_TARGET" -v "$local_ds"
        ZBUD_STATUS=$?
    fi

    if [[ $ZBUD_STATUS -eq 0 ]]; then
        echo -e "${CHAIN_PREFIX}  ${C_GREEN}✅${C_RESET} Replication to $HOP_TARGET successful."
        TRANSFER_DONE=true
    elif [[ $ZBUD_STATUS -eq 2 ]]; then
        HAD_SPLIT_BRAIN=true
        
        if [[ "$REPL_POLICY" == "resilience" ]]; then
            if [[ "$hop_node" == "${NODES_REMAINING[-1]}" ]]; then
                zbud_msg "  ${C_RED}❌ ERROR:${C_RESET} Split-Brain detected on $hop_node. Aborting replication job."
                exit 2
            fi
            echo -e "${CHAIN_PREFIX}  ${C_RED}🚨 FATAL:${C_RESET} Split-Brain detected on $hop_node. Skipping due to policy=resilience..."

            # Send alert for skipped node in resilience mode
            send_smtp_alert "critical" --detail "Split-Brain detected on $hop_node ($remote_ds). Skipping node and continuing chain due to policy=resilience."

            REPLICATION_PARTIAL=true
            TRANSFER_DONE=false
            continue
        else
            zbud_msg "  ${C_RED}❌ ERROR:${C_RESET} Split-Brain detected on $hop_node. Aborting replication job."
            exit 2
        fi
    elif [[ $ZBUD_STATUS -eq 3 ]]; then
        if [[ "$REPL_POLICY" == "resilience" ]]; then
            if [[ "$hop_node" == "${NODES_REMAINING[-1]}" ]]; then
                die "${C_RED}🚨 FATAL:${C_RESET} Destination $hop_node has newer snapshots and Force is disabled. Aborting replication branch." 3
            fi
            echo -e "${CHAIN_PREFIX}  ${C_RED}🚨 FATAL:${C_RESET} Destination $hop_node has newer snapshots and Force is disabled. Skipping due to policy=resilience..."
            REPLICATION_PARTIAL=true
            TRANSFER_DONE=false
            continue
        else
            die "${C_RED}🚨 FATAL:${C_RESET} Destination $hop_node has newer snapshots and Force is disabled. Aborting entire replication job." 3
        fi
    else
        # DISABLED: Searching chain for a better donor
        # TODO: re-enable donor discovery when ready
        # If the destination currently has a split brain error, local replication likely failed due to
        # missing common snapshots. Donor discovery will also fail for the same reason. Skip it.
        : '
        remote_sb=$(ssh "$HOP_TARGET" "zfs get -H -o value zep:error:split-brain $remote_ds" 2>/dev/null)
        if [[ "$remote_sb" == "true" ]]; then
            echo -e "${CHAIN_PREFIX}  ${C_YELLOW}⚠️  WARNING:${C_RESET} Local replication to $hop_node failed. Skipping donor search because local dataset is in a split-brain state."
            DONOR_NODE=""
            SKIP_DONOR_SEARCH=true
        else
            echo -e "${CHAIN_PREFIX}  ${C_YELLOW}⚠️  WARNING:${C_RESET} Local replication to $hop_node failed. Searching chain for a better donor..."
            SKIP_DONOR_SEARCH=false

            if [[ "$IS_DONOR" == true ]]; then
                echo -e "${CHAIN_PREFIX}  ${C_RED}❌ ERROR:${C_RESET} Already acting as donor, skipping recursive discovery."
                DONOR_NODE=""
            else
                DONOR_NODE=$(find_best_donor "$hop_node" "$raw_filesystem")
            fi
        fi

        if [[ -n "$DONOR_NODE" ]]; then
            donor_fqdn=$(resolve_node_fqdn "$DONOR_NODE" "$raw_filesystem")
            donor_user=$(resolve_node_user "$DONOR_NODE" "$raw_filesystem")
            donor_target="${donor_user}@${donor_fqdn}"

            echo -e "${CHAIN_PREFIX}  ${C_GREEN}✅ SUCCESS:${C_RESET} Found donor peer '"'"'$DONOR_NODE'"'"' ($donor_fqdn). Delegating healing of '"'"'$hop_node'"'"'..."

            donor_opts="--alias $DONOR_NODE --target $hop_node --donor"
            if [[ "$ZEP_BW" == "true" ]]; then donor_opts+=" -bw"; fi
            if [[ "$ZEP_COLORS_ENABLED" == "true" && "$ZEP_BW" != "true" ]]; then donor_opts+=" --force-color"; fi

            if ssh "$donor_target" "$ZEPLICATOR_CMD $raw_filesystem $label $keep_fallback $donor_opts"; then
                echo -e "${CHAIN_PREFIX}  ${C_GREEN}✅${C_RESET} Delegated replication from $DONOR_NODE to $hop_node successful."

                # RETRY local replication now that common ground should exist
                echo -e "${CHAIN_PREFIX}  ${C_YELLOW}🔄${C_RESET} Retrying local replication to $hop_node..."
                if zfsbud_core $zfsbud_opts -s "$NEXT_HOP_POOL" -e "ssh $HOP_TARGET" -v "$local_ds"; then
                    echo -e "${CHAIN_PREFIX}  ${C_GREEN}✅${C_RESET} Local replication retry successful."
                    TRANSFER_DONE=true
                else
                    echo -e "${CHAIN_PREFIX}  ${C_RED}❌ ERROR:${C_RESET} Local replication retry failed after donor healing."
                fi
            else
                echo -e "${CHAIN_PREFIX}  ${C_RED}❌ ERROR:${C_RESET} Delegated replication from $DONOR_NODE failed."
            fi
        else
            if [[ "$SKIP_DONOR_SEARCH" != true ]]; then
                echo -e "${CHAIN_PREFIX}  ${C_RED}❌ ERROR:${C_RESET} No suitable donor found for $hop_node."
            fi
        fi
        '
    fi

    if [[ "$TRANSFER_DONE" == false && "$REPL_POLICY" == "fail" ]]; then
        die "Replication to $hop_node failed and no alternative donors succeeded. Aborting due to policy=fail."
    fi

    if [[ "$TRANSFER_DONE" == true ]]; then
        REPLICATION_SUCCESS=true
        
        if [[ "$initial_send" == true ]]; then
            send_smtp_alert "info" --detail "SUCCESS: Initial replication of $local_ds completed successfully to $hop_node ($HOP_TARGET)."
        fi
        
        CASCADE_VERIFIED=false
        if [[ "$PROMOTE" == false && "$IS_DONOR" == false ]]; then
            echo -e "${CHAIN_PREFIX}  ${C_BLUE}🔗${C_RESET} Cascading: triggering downstream chain for $remote_ds on $HOP_TARGET"
            casc_opts="--alias $hop_node"
            if [[ "$initial_send" == true ]]; then casc_opts+=" --init"; fi
            if [[ "$DRY_RUN" == true ]]; then casc_opts+=" --dry-run"; fi
            if [[ "$ZEP_BW" == "true" ]]; then casc_opts+=" -bw"; fi
            if [[ "$ZEP_COLORS_ENABLED" == "true" && "$ZEP_BW" != "true" ]]; then casc_opts+=" --force-color"; fi

            PROPS_ARG=""
            # Pass encoded properties downstream to prefill cache and avoid redundant zfs get traffic
            props_to_pass="${sync_props_data:-$(get_repl_props_encoded "$local_ds")}"
            PROPS_ARG="--sync-props $props_to_pass"

            # Cascade downstream through SSH — output flows through directly
            ssh -o ConnectTimeout="$REPL_SSH_TIMEOUT" "$HOP_TARGET" "export CHAIN_PREFIX=\"${CHAIN_PREFIX}\"; $ZEPLICATOR_CMD $remote_ds $label $keep_fallback $casc_opts $PROPS_ARG --cascaded"
            SSH_STATUS=$?

            if [[ $SSH_STATUS -eq 2 ]]; then
                HAD_SPLIT_BRAIN=true
                if [[ "$REPL_POLICY" == "resilience" ]]; then
                    echo -e "${CHAIN_PREFIX}  ${C_YELLOW}⚠️  WARNING:${C_RESET} Split-Brain detected downstream from $hop_node. Skipping affected downstream nodes due to policy=resilience..."
                    REPLICATION_PARTIAL=true
                    break
                else
                    break
                fi
            fi

            if [[ $SSH_STATUS -eq 0 ]]; then
                echo -e "${CHAIN_PREFIX}  ${C_GREEN}✅ VERIFICATION SUCCESS:${C_RESET} Downstream cascade for $local_ds on $HOP_TARGET completed successfully."
                CASCADE_VERIFIED=true
            else
                echo -e "${CHAIN_PREFIX}  ${C_YELLOW}⚠️  WARNING:${C_RESET} Downstream cascade from $hop_node failed (Code: $SSH_STATUS)."
                REPLICATION_PARTIAL=true
            fi
        else
            # If donor run or dry run, we consider the local transfer as enough for "success" of this hop
            CASCADE_VERIFIED=true
        fi

        if [[ "$CASCADE_VERIFIED" == true ]]; then
            REPLICATION_SUCCESS=true
            break
        elif [[ "$REPL_POLICY" == "fail" ]]; then
            die "Downstream verification/cascade failed for $hop_node. Aborting due to policy=fail."
        else
            echo -e "${CHAIN_PREFIX}  ${C_YELLOW}⚠️  WARNING:${C_RESET} Continuing to next hop in chain due to policy=resilience..."
            REPLICATION_SUCCESS=true # We still count the local transfer as a partial success for shipped marking
            REPLICATION_PARTIAL=true
        fi
    else
        echo -e "${CHAIN_PREFIX}  ${C_RED}❌ ERROR:${C_RESET} Replication to $hop_node failed. Skipping to next available node in chain..."
        REPLICATION_PARTIAL=true
    fi
done

# 3. Final State Reporting & Marking
exit_code=0
if [[ "$REPLICATION_SUCCESS" == true ]]; then
    if [[ "$HAD_SPLIT_BRAIN" == true || "$REPLICATION_PARTIAL" == true ]]; then
        if [[ "$REPL_POLICY" == "resilience" ]]; then
            exit_code=3
        else
            # If policy is fail, partial success is still considered a failure
            [[ "$HAD_SPLIT_BRAIN" == true ]] && exit_code=2 || exit_code=1
        fi
    fi
elif [[ "$HAD_SPLIT_BRAIN" == true ]]; then
    exit_code=2
elif [[ "$REPLICATION_SUCCESS" == false && ${#NODES_REMAINING[@]} -gt 0 ]]; then
    exit_code=1
fi

if [[ "$REPLICATION_SUCCESS" == true ]]; then
    if [[ "$IS_MASTER" == true && "$CASCADED" == false && -n "$LATEST_SNAP" ]]; then
        if [[ "$DRY_RUN" == true ]]; then
            echo "${CHAIN_PREFIX}  🏷️  [DRY RUN] Would mark $LATEST_SNAP as shipped..."
        else
            echo "${CHAIN_PREFIX}  🏷️  Marking sent snapshot $LATEST_SNAP as shipped."
            zfs set zep:shipped=true "$local_ds@$LATEST_SNAP"
        fi
    fi
elif [[ "$exit_code" -ne 0 && "$HAD_SPLIT_BRAIN" != true ]]; then
    die "ERR: All downstream replication attempts failed for chain: ${NODES_REMAINING[*]}" $exit_code
else
    if [[ "$IS_DONOR" == true ]]; then
        echo "${CHAIN_PREFIX}  ℹ️  Donor run complete."
    else
        echo "${CHAIN_PREFIX}  🏁 End of chain ($ME). Reporting state."
    fi
fi

dry_done=""
[[ "$DRY_RUN" == true ]] && dry_done=" [DRY RUN]"
echo -e "${CHAIN_PREFIX}  ${C_GREEN}✅ Done${C_RESET}${dry_done}: $(date)"

# Clean up all replication temp files at the very end
rm -f "$REPL_ERR_FILE" "$REPL_HINT_FILE"
rm -f "${LOCKFILE}.cnt" 2>/dev/null

exit ${exit_code:-0}
