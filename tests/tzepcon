#!/bin/bash
set -e

# Load configuration if available
SCRIPT_DIR=$(dirname "$(readlink -f "$0")")
CONF_FILE="$SCRIPT_DIR/test.conf"
if [[ -f "$CONF_FILE" ]]; then
    source "$CONF_FILE"
fi

NUM_NODES=${NUM_NODES:-3}
SESSION_NAME="zep-test"

# Check if tmux is installed
if ! command -v tmux &> /dev/null; then
    echo "Error: tmux is not installed. Please install it first."
    exit 1
fi

# Kill the session if it already exists to start fresh
tmux kill-session -t "$SESSION_NAME" 2>/dev/null || true

# Start a new detached session with default dimensions to avoid 'size missing' errors
tmux new-session -d -s "$SESSION_NAME" -x 160 -y 40

# Split horizontally: right pane takes 30% width (leaving 70% for the left pane)
# Using -l (size) with % for newer tmux, or falling back to absolute sizing
tmux split-window -h -l 30% -t "$SESSION_NAME:0.0" 2>/dev/null || tmux split-window -h -l 48 -t "$SESSION_NAME:0.0"

# Now we have:
# Pane 0: Left side (70% width)
# Pane 1: Right side (30% width)

# Split the right pane vertically: lower pane takes 70% height (simulator), upper 30% (status)
tmux split-window -v -l 70% -t "$SESSION_NAME:0.1" 2>/dev/null || tmux split-window -v -l 28 -t "$SESSION_NAME:0.1"

# Split the left pane vertically: lower pane takes 30% height (for SMTP Server)
tmux split-window -v -l 30% -t "$SESSION_NAME:0.0" 2>/dev/null || tmux split-window -v -l 12 -t "$SESSION_NAME:0.0"

# Now we have:
# Pane 0: Left main test window (Top)
# Pane 1: Left lower (SMTP Server)
# Pane 2: Right upper (watch status, 30%)
# Pane 3: Right lower (simulator shell, 70%)

# Set up left main pane (Pane 0) - Test Suite
tmux send-keys -t "$SESSION_NAME:0.0" "clear" C-m
tmux send-keys -t "$SESSION_NAME:0.0" "$SCRIPT_DIR/zep_replication_tests.sh $*" C-m

# Set up left lower pane (Pane 1) - SMTP Server
tmux send-keys -t "$SESSION_NAME:0.1" "clear" C-m
tmux send-keys -t "$SESSION_NAME:0.1" "alertcon 1025 --show-mail-only --use-color" C-m

# Set up right upper pane (Pane 2) - Wait for SSH mesh, then watch zep status
DATASET_TO_WATCH="zep-node-1/test-1"
tmux send-keys -t "$SESSION_NAME:0.2" "clear" C-m
tmux send-keys -t "$SESSION_NAME:0.2" "printf 'SSH mesh deploying ['; for i in {1..15}; do printf '#'; sleep 1; done; printf '] ready\n'" C-m
tmux send-keys -t "$SESSION_NAME:0.2" "watch --color -n 10 zep $DATASET_TO_WATCH --status --force-color --alias node1" C-m

# Set up right lower pane (Pane 3) - Simulator shell
tmux send-keys -t "$SESSION_NAME:0.3" "clear" C-m
tmux send-keys -t "$SESSION_NAME:0.3" "cd $SCRIPT_DIR && source sim.sh && cat README.txt" C-m

# Select the simulator pane as the active one
tmux select-pane -t "$SESSION_NAME:0.3"

# Attach to the session
echo "Attaching to tmux session '$SESSION_NAME'..."
tmux set -t "$SESSION_NAME" mouse on
tmux attach-session -t "$SESSION_NAME"
